# ============================================================
# MÓDULO 1: Prefijos y Declaración de Ontología
# ============================================================

@prefix : <http://www.poker-ontology.org/poker#> .
@prefix poker: <http://www.poker-ontology.org/poker#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# ONTOLOGÍA BASE: TEXAS HOLD'EM POKER
# Perfil: OWL 2 DL  |  Serialización: Turtle (.ttl)
# Espacio de nombres: http://www.poker-ontology.org/poker#
# Versión: 2.0.0
# ============================================================
# PROPÓSITO:
#   Vocabulario estructural para modelar partidas de Texas Hold'em.
#   Esta es la ontología BASE. Los clasificadores de manos
#   (Flush, Straight, Three of a Kind, etc.) se implementan
#   como extensiones separadas que importan esta base e introducen
#   sus propias restricciones owl:equivalentClass.
# ============================================================
# SUPOSICIÓN DE MUNDO ABIERTO (OWA):
#   OWL opera bajo OWA: lo que no está afirmado es desconocido, no falso.
#   Para mitigar esto, Suit y Rank se cierran con owl:oneOf, y los
#   52 individuos de cartas se declaran AllDifferent.
# ============================================================

<http://www.poker-ontology.org/poker>
    rdf:type owl:Ontology ;
    rdfs:label "Ontología de Póker" ;
    rdfs:comment "Ontología OWL 2 DL que modela el juego de Texas Hold'em Poker." ;
    owl:versionInfo "2.0.0" .

# ============================================================
# MÓDULO 2: La Baraja (Card, Suit, Rank, Deck)
# ============================================================

# CLASES CERRADAS CON owl:oneOf
# Suit y Rank se definen con owl:equivalentClass + owl:oneOf para
# cerrar el mundo sobre palos y rangos. Sin esto, OWL permitiría
# la existencia de un 5.º palo no declarado (Suposición de Mundo Abierto).
# Con oneOf garantizamos:
#   Suit ≡ {Spades, Hearts, Diamonds, Clubs}  (exactamente 4 palos)
#   Rank ≡ {Two, Three, ..., Ace}              (exactamente 13 rangos)

poker:Suit a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( poker:Spades poker:Hearts poker:Diamonds poker:Clubs )
    ] ;
    rdfs:label "Palo" ;
    rdfs:comment "Palo de una carta. Clase cerrada: exactamente Spades, Hearts, Diamonds, Clubs." .

poker:Rank a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( poker:Two poker:Three poker:Four poker:Five poker:Six poker:Seven poker:Eight poker:Nine poker:Ten poker:Jack poker:Queen poker:King poker:Ace )
    ] ;
    rdfs:label "Rango" ;
    rdfs:comment "Rango de una carta. Clase cerrada: exactamente 13 valores de Two a Ace." .

poker:Card a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:hasSuit ;
        owl:someValuesFrom poker:Suit
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:hasRank ;
        owl:someValuesFrom poker:Rank
    ] ;
    rdfs:label "Carta" ;
    rdfs:comment "Una carta de la baraja estándar de 52 cartas." .

poker:Deck a owl:Class ;
    rdfs:label "Baraja" ;
    rdfs:comment "Una baraja completa de 52 cartas." .

# ============================================================
# MÓDULO 3: Manos y Cartas Comunitarias
# ============================================================

# JERARQUÍA DE MANOS:
#   Hand
#   ├── HoleCards       (= 2 cartas)  cartas privadas del jugador
#   ├── CommunityCards               cartas compartidas
#   │     ├── Flop     (= 3 cartas)  primeras 3 cartas comunitarias
#   │     ├── Turn     (= 1 carta)   4.ª carta comunitaria
#   │     └── River    (= 1 carta)   5.ª carta comunitaria
#   └── BestHand       (= 5 cartas)  mejor combinación del jugador
# Las cardinalidades se implementan con owl:qualifiedCardinality.
# BestHand también requiere hasHandRanking someValuesFrom HandRanking.

poker:Hand a owl:Class ;
    rdfs:label "Mano" ;
    rdfs:comment "Una mano de cartas en el juego." .

poker:HoleCards a owl:Class ;
    rdfs:subClassOf poker:Hand ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:containsCard ;
        owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Card
    ] ;
    rdfs:label "Cartas Privadas" ;
    rdfs:comment "Las 2 cartas privadas repartidas a cada jugador." .

poker:CommunityCards a owl:Class ;
    rdfs:subClassOf poker:Hand ;
    rdfs:label "Cartas Comunitarias" ;
    rdfs:comment "Las cartas comunitarias compartidas por todos los jugadores." .

poker:Flop a owl:Class ;
    rdfs:subClassOf poker:CommunityCards ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:containsCard ;
        owl:qualifiedCardinality "3"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Card
    ] ;
    rdfs:label "Flop" ;
    rdfs:comment "Las primeras 3 cartas comunitarias." .

poker:Turn a owl:Class ;
    rdfs:subClassOf poker:CommunityCards ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:containsCard ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Card
    ] ;
    rdfs:label "Turn" ;
    rdfs:comment "La 4.ª carta comunitaria." .

poker:River a owl:Class ;
    rdfs:subClassOf poker:CommunityCards ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:containsCard ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Card
    ] ;
    rdfs:label "River" ;
    rdfs:comment "La 5.ª y última carta comunitaria." .

poker:BestHand a owl:Class ;
    rdfs:subClassOf poker:Hand ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:containsCard ;
        owl:qualifiedCardinality "5"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Card
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:hasHandRanking ;
        owl:someValuesFrom poker:HandRanking
    ] ;
    rdfs:label "Mejor Mano" ;
    rdfs:comment "La mejor combinación de 5 cartas de un jugador." .

# ============================================================
# MÓDULO 4: Clasificación de Manos (HandRanking)
# ============================================================

# JERARQUÍA DE CLASIFICACIÓN (de menor a mayor fortaleza):
#   HandRanking
#   ├── HighCard       (1) carta más alta — sin combinación
#   ├── OnePair        (2) dos cartas del mismo rango
#   ├── TwoPair        (3) dos pares distintos
#   ├── ThreeOfAKind   (4) tres cartas del mismo rango
#   ├── Straight       (5) cinco cartas consecutivas, distintos palos
#   ├── Flush          (6) cinco cartas del mismo palo
#   ├── FullHouse      (7) trío más un par
#   ├── FourOfAKind    (8) cuatro cartas del mismo rango
#   └── StraightFlush  (9) cinco cartas consecutivas del mismo palo
#         └── RoyalFlush   10-J-Q-K-A del mismo palo (subclase de StraightFlush)
#
# NOTA: RoyalFlush es una SUBCLASE de StraightFlush, no disjunta.
# Las 9 clases base son AllDisjoint entre sí (ver Módulo 11).

poker:HandRanking a owl:Class ;
    rdfs:label "Clasificación de Mano" ;
    rdfs:comment "Categoría de clasificación para una mano de póker." .

poker:HighCard a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Carta Alta" ;
    rdfs:comment "Sin combinación; la carta más alta decide." .

poker:OnePair a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Un Par" ;
    rdfs:comment "Dos cartas del mismo rango." .

poker:TwoPair a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Doble Par" ;
    rdfs:comment "Dos pares distintos." .

poker:ThreeOfAKind a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Trío" ;
    rdfs:comment "Tres cartas del mismo rango." .

poker:Straight a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Escalera" ;
    rdfs:comment "Cinco cartas consecutivas de distintos palos." .

poker:Flush a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Color" ;
    rdfs:comment "Cinco cartas del mismo palo." .

poker:FullHouse a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Full House" ;
    rdfs:comment "Trío más un par." .

poker:FourOfAKind a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Póker" ;
    rdfs:comment "Cuatro cartas del mismo rango." .

poker:StraightFlush a owl:Class ;
    rdfs:subClassOf poker:HandRanking ;
    rdfs:label "Escalera de Color" ;
    rdfs:comment "Cinco cartas consecutivas del mismo palo." .

poker:RoyalFlush a owl:Class ;
    rdfs:subClassOf poker:StraightFlush ;
    rdfs:label "Escalera Real" ;
    rdfs:comment "Escalera de color de Ten a Ace (10-J-Q-K-A del mismo palo)." .

# ============================================================
# MÓDULO 5: Jugadores, Posiciones y Roles
# ============================================================

# CLASES DE ROL DEFINIDAS (owl:equivalentClass):
# Dealer, SmallBlindPlayer y BigBlindPlayer son clases DEFINIDAS:
#   Dealer           ≡ Player ∩ hasPosition.{Button}
#   SmallBlindPlayer ≡ Player ∩ hasPosition.{SmallBlind}
#   BigBlindPlayer   ≡ Player ∩ hasPosition.{BigBlind}
# Un razonador infiere automáticamente el rol del jugador
# según su posición, sin declaración explícita.
#
# NOTA HEADS-UP: ButtonPosition NO es disjunta con
# SmallBlindPosition porque en heads-up (2 jugadores)
# el Button ES el Small Blind. Ver Módulo 11.

poker:Player a owl:Class ;
    rdfs:label "Jugador" ;
    rdfs:comment "Un jugador de póker." .

poker:Position a owl:Class ;
    rdfs:label "Posición" ;
    rdfs:comment "La posición de un jugador en la mesa." .

poker:SmallBlindPosition a owl:Class ;
    rdfs:subClassOf poker:Position ;
    rdfs:label "Posición Small Blind" ;
    rdfs:comment "Posición del jugador que pone el small blind." .

poker:BigBlindPosition a owl:Class ;
    rdfs:subClassOf poker:Position ;
    rdfs:label "Posición Big Blind" ;
    rdfs:comment "Posición del jugador que pone el big blind." .

poker:EarlyPosition a owl:Class ;
    rdfs:subClassOf poker:Position ;
    rdfs:label "Posición Temprana" ;
    rdfs:comment "Posición temprana (Under the Gun)." .

poker:MiddlePosition a owl:Class ;
    rdfs:subClassOf poker:Position ;
    rdfs:label "Posición Media" ;
    rdfs:comment "Posición media en la mesa." .

poker:LatePosition a owl:Class ;
    rdfs:subClassOf poker:Position ;
    rdfs:label "Posición Tardía" ;
    rdfs:comment "Posición tardía (Cutoff)." .

poker:ButtonPosition a owl:Class ;
    rdfs:subClassOf poker:Position ;
    rdfs:label "Posición del Botón" ;
    rdfs:comment "Posición del dealer (botón)." .

poker:Dealer a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Player
            [ a owl:Restriction ; owl:onProperty poker:hasPosition ; owl:hasValue poker:Button ]
        )
    ] ;
    rdfs:label "Dealer" ;
    rdfs:comment "Jugador con la posición del botón (dealer). Clase definida." .

poker:SmallBlindPlayer a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Player
            [ a owl:Restriction ; owl:onProperty poker:hasPosition ; owl:hasValue poker:SmallBlind ]
        )
    ] ;
    rdfs:label "Jugador Small Blind" ;
    rdfs:comment "Jugador en la posición small blind. Clase definida." .

poker:BigBlindPlayer a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Player
            [ a owl:Restriction ; owl:onProperty poker:hasPosition ; owl:hasValue poker:BigBlind ]
        )
    ] ;
    rdfs:label "Jugador Big Blind" ;
    rdfs:comment "Jugador en la posición big blind. Clase definida." .


# ============================================================
# MÓDULO 6: Estructura del Juego (Game, Round)
# ============================================================

# Game es la clase central que conecta todos los elementos.
# RESTRICCIONES ESTRUCTURALES DE UN JUEGO:
#   - Entre 2 y 10 jugadores (minQC 2, maxQC 10)
#   - Exactamente 1 ronda de cada tipo (PreFlop/Flop/Turn/River/Showdown)
#   - Exactamente 1 Flop, 1 Turn, 1 River comunitario (hasCommunityCards)
#   - Al menos 1 MainPot (hasPot minQC 1)
#   - Al menos 1 ganador (hasWinner minQC 1)
# PreFlop requiere acciones obligatorias PostSmallBlind y PostBigBlind.
# Showdown tiene maxQC 0 acciones: no se apuesta en el showdown.
# HeadsUpGame es una clase DEFINIDA: Game ∩ (=2 jugadores) ∩ isHeadsUp=true.

poker:Game a owl:Class ;
    rdfs:label "Partida" ;
    rdfs:comment "Una partida de Texas Hold'em Poker." ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasPlayer ;
        owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Player
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasPlayer ;
        owl:maxQualifiedCardinality "10"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Player
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasRound ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:PreFlop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasRound ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:FlopRound
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasRound ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:TurnRound
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasRound ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:RiverRound
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasRound ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Showdown
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasCommunityCards ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Flop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasCommunityCards ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Turn
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasCommunityCards ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:River
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasPot ;
        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:MainPot
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasWinner ;
        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Player
    ] .

poker:HeadsUpGame a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Game
            [ a owl:Restriction ; owl:onProperty poker:hasPlayer ;
              owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
              owl:onClass poker:Player ]
            [ a owl:Restriction ; owl:onProperty poker:isHeadsUp ;
              owl:hasValue "true"^^xsd:boolean ]
        )
    ] ;
    rdfs:label "Partida Heads-Up" ;
    rdfs:comment "Partida heads-up (exactamente 2 jugadores)." .

poker:Round a owl:Class ;
    rdfs:label "Ronda" ;
    rdfs:comment "Una ronda de juego en una partida de póker." .

poker:PreFlop a owl:Class ;
    rdfs:subClassOf poker:Round ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasAction ;
        owl:someValuesFrom poker:PostSmallBlind
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasAction ;
        owl:someValuesFrom poker:PostBigBlind
    ] ;
    rdfs:label "Pre-Flop" ;
    rdfs:comment "Primera ronda de apuestas, antes de las cartas comunitarias. Incluye ciegas obligatorias." .

poker:FlopRound a owl:Class ;
    rdfs:subClassOf poker:Round ;
    rdfs:label "Ronda del Flop" ;
    rdfs:comment "Ronda de apuestas después del Flop." .

poker:TurnRound a owl:Class ;
    rdfs:subClassOf poker:Round ;
    rdfs:label "Ronda del Turn" ;
    rdfs:comment "Ronda de apuestas después del Turn." .

poker:RiverRound a owl:Class ;
    rdfs:subClassOf poker:Round ;
    rdfs:label "Ronda del River" ;
    rdfs:comment "Ronda de apuestas después del River." .

poker:Showdown a owl:Class ;
    rdfs:subClassOf poker:Round ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:hasAction ;
        owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Action
    ] ;
    rdfs:label "Showdown" ;
    rdfs:comment "Ronda final donde se comparan las manos. Sin apuestas." .

# ============================================================
# MÓDULO 7: Acciones y Apuestas
# ============================================================

# JERARQUÍA DE ACCIONES:
#   Action
#   ├── Fold        retirarse de la mano
#   ├── Check       pasar sin apostar (solo si no hay apuesta previa)
#   ├── Call        igualar la apuesta actual
#   ├── Bet         realizar una nueva apuesta
#   ├── Raise       aumentar una apuesta existente
#   ├── AllIn       apostar todas las fichas (clase abstracta)
#   │     ├── AllInBet    subClassOf AllIn ∩ Bet
#   │     ├── AllInCall   subClassOf AllIn ∩ Call
#   │     └── AllInRaise  subClassOf AllIn ∩ Raise
#   └── PostBlind   ciega obligatoria (no voluntaria)
#         ├── PostSmallBlind  solo en PreFlop, por SmallBlindPlayer
#         └── PostBigBlind    solo en PreFlop, por BigBlindPlayer
#
# AllIn NO es disjunto con Bet/Call/Raise: un all-in ES siempre
# un tipo específico de apuesta al mismo tiempo.
# Action allValuesFrom (PreFlop|FlopRound|TurnRound|RiverRound):
# garantiza que las acciones solo ocurren en rondas de apuesta.

poker:Action a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:performedIn ;
        owl:allValuesFrom [
            a owl:Class ;
            owl:unionOf ( poker:PreFlop poker:FlopRound poker:TurnRound poker:RiverRound )
        ]
    ] ;
    rdfs:label "Acción" ;
    rdfs:comment "Una acción realizada por un jugador durante una ronda de apuestas." .

poker:Fold a owl:Class ;
    rdfs:subClassOf poker:Action ;
    rdfs:label "Fold" ;
    rdfs:comment "Retirarse de la mano." .

poker:Check a owl:Class ;
    rdfs:subClassOf poker:Action ;
    rdfs:label "Check" ;
    rdfs:comment "Pasar sin apostar." .

poker:Call a owl:Class ;
    rdfs:subClassOf poker:Action ;
    rdfs:label "Call" ;
    rdfs:comment "Igualar la apuesta actual." .

poker:Bet a owl:Class ;
    rdfs:subClassOf poker:Action ;
    rdfs:label "Bet" ;
    rdfs:comment "Realizar una apuesta." .

poker:Raise a owl:Class ;
    rdfs:subClassOf poker:Action ;
    rdfs:label "Raise" ;
    rdfs:comment "Aumentar la apuesta." .

poker:AllIn a owl:Class ;
    rdfs:subClassOf poker:Action ;
    rdfs:label "All-In" ;
    rdfs:comment "Apostar todas las fichas." .

poker:AllInBet a owl:Class ;
    rdfs:subClassOf poker:AllIn , poker:Bet ;
    rdfs:label "All-In como Apuesta" ;
    rdfs:comment "All-in como una apuesta." .

poker:AllInCall a owl:Class ;
    rdfs:subClassOf poker:AllIn , poker:Call ;
    rdfs:label "All-In como Igualada" ;
    rdfs:comment "All-in igualando." .

poker:AllInRaise a owl:Class ;
    rdfs:subClassOf poker:AllIn , poker:Raise ;
    rdfs:label "All-In como Subida" ;
    rdfs:comment "All-in subiendo la apuesta." .

poker:PostBlind a owl:Class ;
    rdfs:subClassOf poker:Action ;
    rdfs:label "Poner Ciega" ;
    rdfs:comment "Apuesta de ciega obligatoria." .

poker:PostSmallBlind a owl:Class ;
    rdfs:subClassOf poker:PostBlind ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:performedIn ;
        owl:someValuesFrom poker:PreFlop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:performedBy ;
        owl:someValuesFrom poker:SmallBlindPlayer
    ] ;
    rdfs:label "Poner Small Blind" ;
    rdfs:comment "Poner la ciega pequeña (obligatorio en PreFlop por el jugador en posición small blind)." .

poker:PostBigBlind a owl:Class ;
    rdfs:subClassOf poker:PostBlind ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:performedIn ;
        owl:someValuesFrom poker:PreFlop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:performedBy ;
        owl:someValuesFrom poker:BigBlindPlayer
    ] ;
    rdfs:label "Poner Big Blind" ;
    rdfs:comment "Poner la ciega grande (obligatorio en PreFlop por el jugador en posición big blind)." .

# ============================================================
# MÓDULO 8: Bote, Mesa, Torneo
# ============================================================

# JERARQUÍA DE BOTES:
#   Pot
#   ├── MainPot   bote principal (al menos 1 por partida)
#   └── SidePot   bote secundario (creado cuando un jugador va
#                 all-in por menos del total apostado)
# MainPot y SidePot son disjuntos (ver Módulo 11).
# potSequence indica el orden de los botes secundarios: 1, 2, 3...
# eligibleForPot indica qué jugadores pueden ganar cada bote.
#
# ESTRUCTURAS DE APUESTA (BettingStructure):
#   NoLimitHoldEm   sin límite — se puede apostar todo
#   LimitHoldEm     apuestas de tamaño fijo por calle
#   PotLimitHoldEm  apuesta máxima = tamaño del bote actual

poker:Pot a owl:Class ;
    rdfs:label "Bote" ;
    rdfs:comment "El bote de fichas en juego." .

poker:MainPot a owl:Class ;
    rdfs:subClassOf poker:Pot ;
    rdfs:label "Bote Principal" ;
    rdfs:comment "El bote principal de la partida." .

poker:SidePot a owl:Class ;
    rdfs:subClassOf poker:Pot ;
    rdfs:label "Bote Secundario" ;
    rdfs:comment "Bote secundario creado cuando un jugador va all-in." .

poker:Table a owl:Class ;
    rdfs:label "Mesa" ;
    rdfs:comment "La mesa de póker (física o virtual)." .

poker:Tournament a owl:Class ;
    rdfs:label "Torneo" ;
    rdfs:comment "Un torneo que agrupa múltiples partidas." .

poker:Chip a owl:Class ;
    rdfs:label "Ficha" ;
    rdfs:comment "Ficha de póker (unidad monetaria del juego)." .

poker:BettingStructure a owl:Class ;
    rdfs:label "Estructura de Apuesta" ;
    rdfs:comment "Tipo de estructura de apuesta para la partida." .

poker:NoLimitHoldEm a owl:Class ;
    rdfs:subClassOf poker:BettingStructure ;
    rdfs:label "No Limit Hold'em" ;
    rdfs:comment "Estructura de apuesta sin límite." .

poker:LimitHoldEm a owl:Class ;
    rdfs:subClassOf poker:BettingStructure ;
    rdfs:label "Limit Hold'em" ;
    rdfs:comment "Estructura de apuesta con límite fijo." .

poker:PotLimitHoldEm a owl:Class ;
    rdfs:subClassOf poker:BettingStructure ;
    rdfs:label "Pot Limit Hold'em" ;
    rdfs:comment "Estructura de apuesta con límite de bote." .


# ============================================================
# MÓDULO 9: Propiedades de Objeto
# ============================================================

# ------------------------------------------------------------
# PROPIEDADES DE CARTA (Card → Suit / Rank)
# hasSuit y hasRank son FunctionalProperty: cada carta tiene
# exactamente 1 palo y 1 rango (no puede cambiar).
# containsCard conecta cualquier mano con sus cartas.
# ------------------------------------------------------------

poker:hasSuit a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Card ;
    rdfs:range poker:Suit ;
    rdfs:label "tiene palo" ;
    rdfs:comment "Asocia una carta con su palo." .

poker:hasRank a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Card ;
    rdfs:range poker:Rank ;
    rdfs:label "tiene rango" ;
    rdfs:comment "Asocia una carta con su rango." .

poker:containsCard a owl:ObjectProperty ;
    rdfs:domain poker:Hand ;
    rdfs:range poker:Card ;
    rdfs:label "contiene carta" ;
    rdfs:comment "Asocia una mano con las cartas que contiene." .

# ------------------------------------------------------------
# PROPIEDADES DE MANO (Player ↔ Hand)
# hasHoleCards: Functional + InverseFunctional → 1 jugador tiene
#   1 único HoleCards y cada HoleCards pertenece a 1 solo jugador.
# hasBestHand: Functional → un jugador tiene exactamente 1 mejor mano.
# hasHandRanking: Functional → un BestHand tiene 1 única clasificación.
# ------------------------------------------------------------

poker:hasHoleCards a owl:ObjectProperty , owl:FunctionalProperty , owl:InverseFunctionalProperty ;
    rdfs:domain poker:Player ;
    rdfs:range poker:HoleCards ;
    rdfs:label "tiene cartas privadas" ;
    rdfs:comment "Asocia un jugador con sus cartas privadas." .

poker:hasBestHand a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Player ;
    rdfs:range poker:BestHand ;
    rdfs:label "tiene mejor mano" ;
    rdfs:comment "Asocia un jugador con su mejor mano de 5 cartas." .

poker:hasHandRanking a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:BestHand ;
    rdfs:range poker:HandRanking ;
    rdfs:label "tiene clasificación de mano" ;
    rdfs:comment "Asocia una mejor mano con su categoría de clasificación." .

poker:isDealtTo a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Card ;
    rdfs:range poker:Player ;
    rdfs:label "es repartida a" ;
    rdfs:comment "Indica a qué jugador fue repartida una carta." .

# ------------------------------------------------------------
# PROPIEDADES INVERSAS (Game ↔ Player / Action ↔ Round)
# hasPlayer/participatesIn, makesAction/performedBy,
# performedIn/hasAction son pares de propiedades inversas.
# hasSidePot es subPropertyOf hasPot: todo bote secundario es un bote.
# ------------------------------------------------------------

poker:hasPlayer a owl:ObjectProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:Player ;
    owl:inverseOf poker:participatesIn ;
    rdfs:label "tiene jugador" ;
    rdfs:comment "Asocia una partida con un jugador participante." .

poker:participatesIn a owl:ObjectProperty ;
    rdfs:domain poker:Player ;
    rdfs:range poker:Game ;
    owl:inverseOf poker:hasPlayer ;
    rdfs:label "participa en" ;
    rdfs:comment "Asocia un jugador con la partida en la que participa." .

poker:hasWinner a owl:ObjectProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:Player ;
    rdfs:label "tiene ganador" ;
    rdfs:comment "Asocia una partida con su(s) jugador(es) ganador(es)." .

poker:hasRound a owl:ObjectProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:Round ;
    rdfs:label "tiene ronda" ;
    rdfs:comment "Asocia una partida con una ronda de juego." .

poker:hasPot a owl:ObjectProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:Pot ;
    rdfs:label "tiene bote" ;
    rdfs:comment "Asocia una partida con un bote." .

poker:hasSidePot a owl:ObjectProperty ;
    rdfs:subPropertyOf poker:hasPot ;
    rdfs:domain poker:Game ;
    rdfs:range poker:SidePot ;
    rdfs:label "tiene bote secundario" ;
    rdfs:comment "Asocia una partida con un bote secundario." .

poker:hasCommunityCards a owl:ObjectProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:CommunityCards ;
    rdfs:label "tiene cartas comunitarias" ;
    rdfs:comment "Asocia una partida con sus cartas comunitarias." .

poker:makesAction a owl:ObjectProperty ;
    rdfs:domain poker:Player ;
    rdfs:range poker:Action ;
    owl:inverseOf poker:performedBy ;
    rdfs:label "realiza acción" ;
    rdfs:comment "Asocia un jugador con una acción que realiza." .

poker:performedBy a owl:ObjectProperty ;
    rdfs:domain poker:Action ;
    rdfs:range poker:Player ;
    owl:inverseOf poker:makesAction ;
    rdfs:label "realizada por" ;
    rdfs:comment "Indica qué jugador realizó una acción." .

poker:performedIn a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Action ;
    rdfs:range poker:Round ;
    owl:inverseOf poker:hasAction ;
    rdfs:label "realizada en" ;
    rdfs:comment "Indica en qué ronda se realizó una acción." .

poker:hasAction a owl:ObjectProperty ;
    rdfs:domain poker:Round ;
    rdfs:range poker:Action ;
    owl:inverseOf poker:performedIn ;
    rdfs:label "tiene acción" ;
    rdfs:comment "Asocia una ronda con una acción ocurrida en ella." .

poker:hasPosition a owl:ObjectProperty ;
    rdfs:domain poker:Player ;
    rdfs:range poker:Position ;
    rdfs:label "tiene posición" ;
    rdfs:comment "Asocia un jugador con su posición en la mesa." .

poker:usesStructure a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:BettingStructure ;
    rdfs:label "usa estructura" ;
    rdfs:comment "Asocia una partida con su estructura de apuesta." .

poker:isPartOf a owl:ObjectProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:Tournament ;
    rdfs:label "es parte de" ;
    rdfs:comment "Asocia una partida con el torneo al que pertenece." .

poker:hasTable a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Game ;
    rdfs:range poker:Table ;
    rdfs:label "tiene mesa" ;
    rdfs:comment "Asocia una partida con la mesa donde se juega." .

poker:winsHand a owl:ObjectProperty ;
    rdfs:domain poker:Player ;
    rdfs:range poker:BestHand ;
    rdfs:label "gana mano" ;
    rdfs:comment "Asocia un jugador con la mejor mano con la que ganó." .

# ------------------------------------------------------------
# PROPIEDAD beats (TransitiveProperty)
# Relaciona clasificaciones: RoyalFlush beats StraightFlush, etc.
# Por transitividad, el razonador infiere automáticamente que
# RoyalFlush beats HighCard sin declaración explícita.
# Se declaran 9 relaciones directas → 45 pares totales inferidos.
# ------------------------------------------------------------

poker:beats a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:domain poker:HandRanking ;
    rdfs:range poker:HandRanking ;
    rdfs:label "supera" ;
    rdfs:comment "Indica que una clasificación de mano supera a otra. Propiedad transitiva." .

poker:eligibleForPot a owl:ObjectProperty ;
    rdfs:domain poker:Player ;
    rdfs:range poker:Pot ;
    rdfs:label "elegible para bote" ;
    rdfs:comment "Indica que un jugador es elegible para ganar un bote." .

# ============================================================
# MÓDULO 10: Propiedades de Datos
# ============================================================

# Las Propiedades de Datos registran valores escalares del dominio.
# OWL no puede calcular ni sumar: los valores se registran como
# hechos (p. ej., hasPotSize registra el bote, no lo calcula).
# Las marcadas FunctionalProperty garantizan unicidad del valor
# por individuo (p. ej., cada Rank tiene un único hasRankValue).

poker:hasRankValue a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Rank ;
    rdfs:range xsd:integer ;
    rdfs:label "tiene valor de rango" ;
    rdfs:comment "Valor numérico del rango (2-14)." .

poker:hasRankValueLow a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Rank ;
    rdfs:range xsd:integer ;
    rdfs:label "tiene valor de rango bajo" ;
    rdfs:comment "Valor alternativo de rango bajo (solo el As = 1)." .

poker:hasChipCount a owl:DatatypeProperty ;
    rdfs:domain poker:Player ;
    rdfs:range xsd:integer ;
    rdfs:label "tiene conteo de fichas" ;
    rdfs:comment "Conteo de fichas del jugador." .

poker:hasBetAmount a owl:DatatypeProperty ;
    rdfs:domain poker:Action ;
    rdfs:range xsd:decimal ;
    rdfs:label "tiene monto de apuesta" ;
    rdfs:comment "Monto de la apuesta." .

poker:hasPotSize a owl:DatatypeProperty ;
    rdfs:domain poker:Pot ;
    rdfs:range xsd:decimal ;
    rdfs:label "tiene tamaño del bote" ;
    rdfs:comment "Tamaño del bote." .

poker:isBlind a owl:DatatypeProperty ;
    rdfs:domain poker:Player ;
    rdfs:range xsd:boolean ;
    rdfs:label "es ciega" ;
    rdfs:comment "Indica si el jugador está en una posición de ciega." .

poker:isAllIn a owl:DatatypeProperty ;
    rdfs:domain poker:Player ;
    rdfs:range xsd:boolean ;
    rdfs:label "está all-in" ;
    rdfs:comment "Indica si el jugador fue all-in." .

poker:isFolded a owl:DatatypeProperty ;
    rdfs:domain poker:Player ;
    rdfs:range xsd:boolean ;
    rdfs:label "se retiró" ;
    rdfs:comment "Indica si el jugador se retiró (fold)." .

poker:playerName a owl:DatatypeProperty ;
    rdfs:domain poker:Player ;
    rdfs:range xsd:string ;
    rdfs:label "nombre del jugador" ;
    rdfs:comment "Nombre del jugador." .

poker:seatNumber a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Player ;
    rdfs:range xsd:integer ;
    rdfs:label "número de asiento" ;
    rdfs:comment "Número de asiento (1-10)." .

poker:tableSize a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Table ;
    rdfs:range xsd:integer ;
    rdfs:label "tamaño de la mesa" ;
    rdfs:comment "Número de asientos en la mesa." .

poker:gameId a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Game ;
    rdfs:range xsd:string ;
    rdfs:label "ID de partida" ;
    rdfs:comment "Identificador único de la partida." .

poker:handNumber a owl:DatatypeProperty ;
    rdfs:domain poker:Game ;
    rdfs:range xsd:integer ;
    rdfs:label "número de mano" ;
    rdfs:comment "Número de mano en la sesión." .

poker:hasDealerButton a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Player ;
    rdfs:range xsd:boolean ;
    rdfs:label "tiene botón de dealer" ;
    rdfs:comment "Indica si el jugador tiene el botón de dealer." .

poker:isHeadsUp a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Game ;
    rdfs:range xsd:boolean ;
    rdfs:label "es heads-up" ;
    rdfs:comment "Indica si la partida es heads-up (2 jugadores)." .

poker:potSequence a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:SidePot ;
    rdfs:range xsd:integer ;
    rdfs:label "secuencia del bote" ;
    rdfs:comment "Orden del bote secundario." .


# ============================================================
# MÓDULO 11: Axiomas Estructurales y Restricciones
# ============================================================

# Axiomas globales que garantizan la consistencia de la ontología.
# Un razonador (HermiT/Pellet) detecta inconsistencias si algún
# axioma es violado (p. ej., instanciar algo como MainPot y SidePot
# al mismo tiempo → inconsistente).

# Disyunción de Clasificaciones de Mano (9 clases base, RoyalFlush excluido)
[] a owl:AllDisjointClasses ;
    owl:members ( poker:HighCard poker:OnePair poker:TwoPair poker:ThreeOfAKind
                  poker:Straight poker:Flush poker:FullHouse poker:FourOfAKind
                  poker:StraightFlush ) .

# Disyunción de Rondas (una ronda no puede ser dos tipos a la vez)
[] a owl:AllDisjointClasses ;
    owl:members ( poker:PreFlop poker:FlopRound poker:TurnRound poker:RiverRound poker:Showdown ) .

# Disyunción de Acciones Base (AllIn omitido: es una clase compuesta)
[] a owl:AllDisjointClasses ;
    owl:members ( poker:Fold poker:Check poker:Call poker:Bet poker:Raise ) .

# PostBlind es distinto de todas las acciones voluntarias
poker:PostBlind owl:disjointWith poker:Fold .
poker:PostBlind owl:disjointWith poker:Check .
poker:PostBlind owl:disjointWith poker:Call .
poker:PostBlind owl:disjointWith poker:Bet .
poker:PostBlind owl:disjointWith poker:Raise .

# Disyunción de Estructuras de Apuesta
[] a owl:AllDisjointClasses ;
    owl:members ( poker:NoLimitHoldEm poker:LimitHoldEm poker:PotLimitHoldEm ) .

# Disyunción de Cartas Comunitarias
[] a owl:AllDisjointClasses ;
    owl:members ( poker:Flop poker:Turn poker:River ) .

# MainPot disjunto con SidePot
poker:MainPot owl:disjointWith poker:SidePot .

# Disyunciones de Posición (compatibles con heads-up de 2 jugadores)
# BigBlindPosition es SIEMPRE exclusiva con todas las demás
# ButtonPosition NO es disjunta con SmallBlindPosition (coinciden en heads-up)
poker:BigBlindPosition owl:disjointWith poker:SmallBlindPosition .
poker:BigBlindPosition owl:disjointWith poker:ButtonPosition .
poker:BigBlindPosition owl:disjointWith poker:EarlyPosition .
poker:BigBlindPosition owl:disjointWith poker:MiddlePosition .
poker:BigBlindPosition owl:disjointWith poker:LatePosition .

# Las posiciones intermedias son mutuamente exclusivas en partidas de 3+ jugadores
poker:EarlyPosition owl:disjointWith poker:MiddlePosition .
poker:EarlyPosition owl:disjointWith poker:LatePosition .
poker:MiddlePosition owl:disjointWith poker:LatePosition .
# NOTA: ButtonPosition NO es disjunta con SmallBlindPosition (coinciden en heads-up)

# ============================================================
# MÓDULO 12: Individuos (ABox)
# ============================================================

# La ABox define los individuos concretos del dominio.
# Total: 88 individuos
#   4  palos (Suit)                     — cerrados por owl:oneOf en TBox
#   13 rangos (Rank)                    — As con valor dual: 14 (alto) y 1 (bajo)
#   52 cartas (Card)                    — 13 rangos × 4 palos
#   6  posiciones (Position)
#   3  estructuras de apuesta (BettingStructure)
#   10 clasificaciones de mano (HandRanking) — incluyendo RoyalFlush

# Palos (4 individuos)
poker:Spades a poker:Suit ;
    rdfs:label "Picas" .
poker:Hearts a poker:Suit ;
    rdfs:label "Corazones" .
poker:Diamonds a poker:Suit ;
    rdfs:label "Diamantes" .
poker:Clubs a poker:Suit ;
    rdfs:label "Tréboles" .

# Valores de rango de Two (hasRankValue 2) a Ace (hasRankValue 14).
# El As también tiene hasRankValueLow=1 para la escalera baja
# (A-2-3-4-5, la 'rueda'). OWL no suma; las aplicaciones externas
# (SPARQL/Python) usan estos datos para la lógica de evaluación.
# Rangos (13 individuos)
poker:Two a poker:Rank ;
    poker:hasRankValue 2 ;
    rdfs:label "Dos" .
poker:Three a poker:Rank ;
    poker:hasRankValue 3 ;
    rdfs:label "Tres" .
poker:Four a poker:Rank ;
    poker:hasRankValue 4 ;
    rdfs:label "Cuatro" .
poker:Five a poker:Rank ;
    poker:hasRankValue 5 ;
    rdfs:label "Cinco" .
poker:Six a poker:Rank ;
    poker:hasRankValue 6 ;
    rdfs:label "Seis" .
poker:Seven a poker:Rank ;
    poker:hasRankValue 7 ;
    rdfs:label "Siete" .
poker:Eight a poker:Rank ;
    poker:hasRankValue 8 ;
    rdfs:label "Ocho" .
poker:Nine a poker:Rank ;
    poker:hasRankValue 9 ;
    rdfs:label "Nueve" .
poker:Ten a poker:Rank ;
    poker:hasRankValue 10 ;
    rdfs:label "Diez" .
poker:Jack a poker:Rank ;
    poker:hasRankValue 11 ;
    rdfs:label "Jota" .
poker:Queen a poker:Rank ;
    poker:hasRankValue 12 ;
    rdfs:label "Reina" .
poker:King a poker:Rank ;
    poker:hasRankValue 13 ;
    rdfs:label "Rey" .
poker:Ace a poker:Rank ;
    poker:hasRankValue 14 ;
    poker:hasRankValueLow 1 ;
    rdfs:label "As" .

# Convención de nombres: {Rango}Of{Palo}
# Ejemplos: TwoOfSpades, AceOfHearts, KingOfDiamonds, JackOfClubs
# Cada carta declara hasSuit y hasRank explícitamente.
# Esto permite consultas SPARQL y el axioma AllDifferent.
# Cartas (52 individuos)
poker:TwoOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Two ;
    rdfs:label "Dos de Picas" .
poker:ThreeOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Three ;
    rdfs:label "Tres de Picas" .
poker:FourOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Four ;
    rdfs:label "Cuatro de Picas" .
poker:FiveOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Five ;
    rdfs:label "Cinco de Picas" .
poker:SixOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Six ;
    rdfs:label "Seis de Picas" .
poker:SevenOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Seven ;
    rdfs:label "Siete de Picas" .
poker:EightOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Eight ;
    rdfs:label "Ocho de Picas" .
poker:NineOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Nine ;
    rdfs:label "Nueve de Picas" .
poker:TenOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Ten ;
    rdfs:label "Diez de Picas" .
poker:JackOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Jack ;
    rdfs:label "Jota de Picas" .
poker:QueenOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Queen ;
    rdfs:label "Reina de Picas" .
poker:KingOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:King ;
    rdfs:label "Rey de Picas" .
poker:AceOfSpades a poker:Card ;
    poker:hasSuit poker:Spades ;
    poker:hasRank poker:Ace ;
    rdfs:label "As de Picas" .

poker:TwoOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Two ;
    rdfs:label "Dos de Corazones" .
poker:ThreeOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Three ;
    rdfs:label "Tres de Corazones" .
poker:FourOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Four ;
    rdfs:label "Cuatro de Corazones" .
poker:FiveOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Five ;
    rdfs:label "Cinco de Corazones" .
poker:SixOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Six ;
    rdfs:label "Seis de Corazones" .
poker:SevenOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Seven ;
    rdfs:label "Siete de Corazones" .
poker:EightOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Eight ;
    rdfs:label "Ocho de Corazones" .
poker:NineOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Nine ;
    rdfs:label "Nueve de Corazones" .
poker:TenOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Ten ;
    rdfs:label "Diez de Corazones" .
poker:JackOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Jack ;
    rdfs:label "Jota de Corazones" .
poker:QueenOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Queen ;
    rdfs:label "Reina de Corazones" .
poker:KingOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:King ;
    rdfs:label "Rey de Corazones" .
poker:AceOfHearts a poker:Card ;
    poker:hasSuit poker:Hearts ;
    poker:hasRank poker:Ace ;
    rdfs:label "As de Corazones" .

poker:TwoOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Two ;
    rdfs:label "Dos de Diamantes" .
poker:ThreeOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Three ;
    rdfs:label "Tres de Diamantes" .
poker:FourOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Four ;
    rdfs:label "Cuatro de Diamantes" .
poker:FiveOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Five ;
    rdfs:label "Cinco de Diamantes" .
poker:SixOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Six ;
    rdfs:label "Seis de Diamantes" .
poker:SevenOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Seven ;
    rdfs:label "Siete de Diamantes" .
poker:EightOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Eight ;
    rdfs:label "Ocho de Diamantes" .
poker:NineOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Nine ;
    rdfs:label "Nueve de Diamantes" .
poker:TenOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Ten ;
    rdfs:label "Diez de Diamantes" .
poker:JackOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Jack ;
    rdfs:label "Jota de Diamantes" .
poker:QueenOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Queen ;
    rdfs:label "Reina de Diamantes" .
poker:KingOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:King ;
    rdfs:label "Rey de Diamantes" .
poker:AceOfDiamonds a poker:Card ;
    poker:hasSuit poker:Diamonds ;
    poker:hasRank poker:Ace ;
    rdfs:label "As de Diamantes" .

poker:TwoOfClubs a poker:Card ;
    poker:hasSuit poker:Clubs ;
    poker:hasRank poker:Two ;
    rdfs:label "Dos de Tréboles" .
