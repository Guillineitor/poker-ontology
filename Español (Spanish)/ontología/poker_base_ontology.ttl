# Posiciones (6 individuos)
poker:SmallBlind a poker:SmallBlindPosition ;
    rdfs:label "Ciega Pequeña" .
poker:BigBlind a poker:BigBlindPosition ;
    rdfs:label "Ciega Grande" .
poker:UTG a poker:EarlyPosition ;
    rdfs:label "Under the Gun" .
poker:MiddlePos a poker:MiddlePosition ;
    rdfs:label "Posición Media" .
poker:CutOff a poker:LatePosition ;
    rdfs:label "Cutoff" .
poker:Button a poker:ButtonPosition ;
    rdfs:label "Botón" .

# Estructuras de Apuesta (3 individuos)
poker:NLHE a poker:NoLimitHoldEm ;
    rdfs:label "No Limit Texas Hold'em" .
poker:LHE a poker:LimitHoldEm ;
    rdfs:label "Limit Texas Hold'em" .
poker:PLHE a poker:PotLimitHoldEm ;
    rdfs:label "Pot Limit Texas Hold'em" .

# Clasificaciones de Mano (10 individuos)
poker:HighCardRanking a poker:HighCard ;
    rdfs:label "Clasificación Carta Alta" .
poker:OnePairRanking a poker:OnePair ;
    rdfs:label "Clasificación Un Par" .
poker:TwoPairRanking a poker:TwoPair ;
    rdfs:label "Clasificación Doble Par" .
poker:ThreeOfAKindRanking a poker:ThreeOfAKind ;
    rdfs:label "Clasificación Trío" .
poker:StraightRanking a poker:Straight ;
    rdfs:label "Clasificación Escalera" .
poker:FlushRanking a poker:Flush ;
    rdfs:label "Clasificación Color" .
poker:FullHouseRanking a poker:FullHouse ;
    rdfs:label "Clasificación Full House" .
poker:FourOfAKindRanking a poker:FourOfAKind ;
    rdfs:label "Clasificación Póker" .
poker:StraightFlushRanking a poker:StraightFlush ;
    rdfs:label "Clasificación Escalera de Color" .
poker:RoyalFlushRanking a poker:RoyalFlush ;
    rdfs:label "Clasificación Escalera Real" .

# Cadena de beats: 9 relaciones directas, 36 pares inferidos por transitividad
# Orden de mayor a menor fortaleza:
# RoyalFlush > StraightFlush > FourOfAKind > FullHouse > Flush
#   > Straight > ThreeOfAKind > TwoPair > OnePair > HighCard
# El razonador infiere p. ej. FourOfAKindRanking beats OnePairRanking.
poker:RoyalFlushRanking poker:beats poker:StraightFlushRanking .
poker:StraightFlushRanking poker:beats poker:FourOfAKindRanking .
poker:FourOfAKindRanking poker:beats poker:FullHouseRanking .
poker:FullHouseRanking poker:beats poker:FlushRanking .
poker:FlushRanking poker:beats poker:StraightRanking .
poker:StraightRanking poker:beats poker:ThreeOfAKindRanking .
poker:ThreeOfAKindRanking poker:beats poker:TwoPairRanking .
poker:TwoPairRanking poker:beats poker:OnePairRanking .
poker:OnePairRanking poker:beats poker:HighCardRanking .

# Axiomas AllDifferent: garantizan que los individuos de cada grupo
# son distintos entre sí (Suposición de Nombres Únicos local).
# Bajo OWA, dos nombres diferentes podrían referirse al mismo objeto.
# AllDifferent cierra este mundo para los 52 individuos de cartas,
# los 4 palos, los 13 rangos, posiciones y clasificaciones.
# Axiomas AllDifferent

# 4 palos distintos
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:Spades poker:Hearts poker:Diamonds poker:Clubs ) .

# 13 rangos distintos
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:Two poker:Three poker:Four poker:Five poker:Six poker:Seven poker:Eight poker:Nine poker:Ten poker:Jack poker:Queen poker:King poker:Ace ) .

# 52 cartas distintas
[] a owl:AllDifferent ;
    owl:distinctMembers (
        poker:TwoOfSpades poker:ThreeOfSpades poker:FourOfSpades poker:FiveOfSpades
        poker:SixOfSpades poker:SevenOfSpades poker:EightOfSpades poker:NineOfSpades
        poker:TenOfSpades poker:JackOfSpades poker:QueenOfSpades poker:KingOfSpades
        poker:AceOfSpades poker:TwoOfHearts poker:ThreeOfHearts poker:FourOfHearts
        poker:FiveOfHearts poker:SixOfHearts poker:SevenOfHearts poker:EightOfHearts
        poker:NineOfHearts poker:TenOfHearts poker:JackOfHearts poker:QueenOfHearts
        poker:KingOfHearts poker:AceOfHearts poker:TwoOfDiamonds poker:ThreeOfDiamonds
        poker:FourOfDiamonds poker:FiveOfDiamonds poker:SixOfDiamonds poker:SevenOfDiamonds
        poker:EightOfDiamonds poker:NineOfDiamonds poker:TenOfDiamonds poker:JackOfDiamonds
        poker:QueenOfDiamonds poker:KingOfDiamonds poker:AceOfDiamonds poker:TwoOfClubs
        poker:ThreeOfClubs poker:FourOfClubs poker:FiveOfClubs poker:SixOfClubs
        poker:SevenOfClubs poker:EightOfClubs poker:NineOfClubs poker:TenOfClubs
        poker:JackOfClubs poker:QueenOfClubs poker:KingOfClubs poker:AceOfClubs
    ) .

# 6 posiciones distintas
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:SmallBlind poker:BigBlind poker:UTG poker:MiddlePos poker:CutOff poker:Button ) .

# 10 clasificaciones distintas
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:HighCardRanking poker:OnePairRanking poker:TwoPairRanking poker:ThreeOfAKindRanking poker:StraightRanking poker:FlushRanking poker:FullHouseRanking poker:FourOfAKindRanking poker:StraightFlushRanking poker:RoyalFlushRanking ) .

# 3 estructuras de apuesta distintas
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:NLHE poker:LHE poker:PLHE ) .

# ============================================================
# MÓDULO 13 OMITIDO — EXTENSIÓN DE CLASIFICADORES
# ============================================================
# Esta es la ontología BASE. Para construir un clasificador,
# crea un nuevo archivo .ttl que importe esta base e introduzca
# sus propias clases con owl:equivalentClass. Ejemplo:
#
#   @prefix poker: <http://www.poker-ontology.org/poker#> .
#   <http://example.org/clasificadores>
#       owl:imports <http://www.poker-ontology.org/poker> .
#
#   ex:ColorDiamantes a owl:Class ;
#       rdfs:subClassOf poker:BestHand ;
#       owl:equivalentClass [
#           owl:intersectionOf (
#               poker:BestHand
#               [ owl:onProperty poker:containsCard ;
#                 owl:allValuesFrom
#                   [ owl:onProperty poker:hasSuit ;
#                     owl:hasValue poker:Diamonds ] ] ) ] .
# ============================================================
