    rdfs:label "Full House by Cards" ;
    rdfs:comment "BestHand with trips and a pair of different ranks (156 variants = 13 x 12)." .

# 13.9 Flush by Cards Pattern (4 variants)
# FlushByCardsBestHand: qualifiedCardinality 5 for each suit class.
# Note: includes Straight Flush and Royal Flush as special cases.
# Fine distinction is made via hasHandRanking.

poker:FlushByCardsBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ;
              owl:unionOf (
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:qualifiedCardinality "5"^^xsd:nonNegativeInteger ; owl:onClass poker:SpadesCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:qualifiedCardinality "5"^^xsd:nonNegativeInteger ; owl:onClass poker:HeartsCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:qualifiedCardinality "5"^^xsd:nonNegativeInteger ; owl:onClass poker:DiamondsCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:qualifiedCardinality "5"^^xsd:nonNegativeInteger ; owl:onClass poker:ClubsCard ]
              )
            ]
        )
    ] ;
    rdfs:label "Flush by Cards" ;
    rdfs:comment "BestHand with 5 cards of the same suit (4 variants). Semantic superclass of Straight Flush." .

# 13.10 Straight by Ranks Pattern (10 variants)
# StraightByRanksBestHand: minQualifiedCardinality 1 for each required rank.
# Note: includes Straight Flush and Royal Flush. Distinction via hasHandRanking.

poker:StraightByRanksBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ;
              owl:unionOf (
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass poker:AceRankCard ]
