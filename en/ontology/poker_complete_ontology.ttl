    rdfs:label "Two Pair by Cards" ;
    rdfs:comment "BestHand with at least 2 cards of two distinct ranks (78 variants = C(13,2)). Includes Full House." .

# 13.13 One Pair by Cards Pattern (13 variants)
# OnePairByCardsBestHand: minQualifiedCardinality 2 for each rank.
# This is the broadest condition: also covers Two Pair, Three of a Kind,
# Full House, and Four of a Kind (all have at least one pair).

poker:OnePairByCardsBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ;
              owl:unionOf (
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:TwoRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:ThreeRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:FourRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:FiveRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:SixRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:SevenRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:EightRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:NineRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:TenRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:JackRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:QueenRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:KingRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ; owl:onClass poker:AceRankCard ]
              )
            ]
        )
    ] ;
    rdfs:label "One Pair by Cards" ;
    rdfs:comment "BestHand with at least 2 cards of the same rank (13 variants). Includes Two Pair, Three of a Kind, Full House, Four of a Kind." .

# 13.14 High Card by Complement Pattern
# HighCardByCardsBestHand ≡ BestHand
#   ∩ ¬OnePairByCardsBestHand     (no pair of any rank)
#   ∩ ¬StraightByRanksBestHand   (no 5 ranks of any straight)
#   ∩ ¬FlushByCardsBestHand      (no 5 cards of the same suit)
# WARNING: requires closed world (all cards assigned).
# In a benchmark with complete ABox this pattern works correctly.

poker:HighCardByCardsBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ; owl:complementOf poker:OnePairByCardsBestHand ]
            [ a owl:Class ; owl:complementOf poker:StraightByRanksBestHand ]
            [ a owl:Class ; owl:complementOf poker:FlushByCardsBestHand ]
        )
    ] ;
    rdfs:label "High Card by Complement" ;
    rdfs:comment "BestHand with no pair, straight, or flush (requires closed world over assigned cards)." .

