# beats chain: 9 direct relations, 36 pairs inferred by transitivity
poker:RoyalFlushRanking poker:beats poker:StraightFlushRanking .
poker:StraightFlushRanking poker:beats poker:FourOfAKindRanking .
poker:FourOfAKindRanking poker:beats poker:FullHouseRanking .
poker:FullHouseRanking poker:beats poker:FlushRanking .
poker:FlushRanking poker:beats poker:StraightRanking .
poker:StraightRanking poker:beats poker:ThreeOfAKindRanking .
poker:ThreeOfAKindRanking poker:beats poker:TwoPairRanking .
poker:TwoPairRanking poker:beats poker:OnePairRanking .
poker:OnePairRanking poker:beats poker:HighCardRanking .

# AllDifferent Axioms

# 4 distinct suits
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:Spades poker:Hearts poker:Diamonds poker:Clubs ) .

# 13 distinct ranks
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:Two poker:Three poker:Four poker:Five poker:Six poker:Seven poker:Eight poker:Nine poker:Ten poker:Jack poker:Queen poker:King poker:Ace ) .

# 52 distinct cards
[] a owl:AllDifferent ;
    owl:distinctMembers (
        poker:TwoOfSpades poker:ThreeOfSpades poker:FourOfSpades poker:FiveOfSpades
        poker:SixOfSpades poker:SevenOfSpades poker:EightOfSpades poker:NineOfSpades
        poker:TenOfSpades poker:JackOfSpades poker:QueenOfSpades poker:KingOfSpades
        poker:AceOfSpades poker:TwoOfHearts poker:ThreeOfHearts poker:FourOfHearts
        poker:FiveOfHearts poker:SixOfHearts poker:SevenOfHearts poker:EightOfHearts
        poker:NineOfHearts poker:TenOfHearts poker:JackOfHearts poker:QueenOfHearts
        poker:KingOfHearts poker:AceOfHearts poker:TwoOfDiamonds poker:ThreeOfDiamonds
        poker:FourOfDiamonds poker:FiveOfDiamonds poker:SixOfDiamonds poker:SevenOfDiamonds
        poker:EightOfDiamonds poker:NineOfDiamonds poker:TenOfDiamonds poker:JackOfDiamonds
        poker:QueenOfDiamonds poker:KingOfDiamonds poker:AceOfDiamonds poker:TwoOfClubs
        poker:ThreeOfClubs poker:FourOfClubs poker:FiveOfClubs poker:SixOfClubs
        poker:SevenOfClubs poker:EightOfClubs poker:NineOfClubs poker:TenOfClubs
        poker:JackOfClubs poker:QueenOfClubs poker:KingOfClubs poker:AceOfClubs
    ) .

# 6 distinct positions
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:SmallBlind poker:BigBlind poker:UTG poker:MiddlePos poker:CutOff poker:Button ) .

# 10 distinct rankings
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:HighCardRanking poker:OnePairRanking poker:TwoPairRanking poker:ThreeOfAKindRanking poker:StraightRanking poker:FlushRanking poker:FullHouseRanking poker:FourOfAKindRanking poker:StraightFlushRanking poker:RoyalFlushRanking ) .

# 3 distinct betting structures
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:NLHE poker:LHE poker:PLHE ) .

# ============================================================
# MODULE 13: Hand Inference Layer
# ============================================================

# This module defines owl:equivalentClass patterns that allow an OWL 2 DL
# reasoner (HermiT/Pellet/FaCT++) to automatically classify poker hands.
# REQUIREMENT: the 5 cards of the BestHand must be explicitly assigned
# with containsCard for the reasoner to activate classification.
#
# Module contents:
#   13.1  4  suit helper classes        (SpadesCard, HeartsCard, ...)
#   13.2  13 rank helper classes         (TwoRankCard, AceRankCard, ...)
#   13.3  10 BestHand-by-ranking classes (OnePairBestHand, FlushBestHand, ...)
#   13.4  Royal Flush by cards           (4  variants: one per suit)
#   13.5  Steel Wheel by cards           (4  variants: one per suit)
#   13.6  Standard Straight Flush        (32 variants: 8 ranges × 4 suits)
#   13.7  Four of a Kind by cards        (13 variants: one per rank)
#   13.8  Full House by cards             (156 variants: 13 trips × 12 pairs)
#   13.9  Flush by cards                  (4  variants: one per suit)
#   13.10 Straight by ranks               (10 variants)
#   13.11 Three of a Kind by cards        (13 variants)
#   13.12 Two Pair by cards               (78 variants: C(13,2))
#   13.13 One Pair by cards               (13 variants)
#   13.14 High Card by complement         (1  class, requires closed world)

# 13.1 Suit Helper Classes (4 classes)
# XxxCard ≡ Card ∩ hasSuit.{Xxx}
# Enable owl:qualifiedCardinality over cards of a specific suit.
# Example: =5 containsCard SpadesCard detects a Spades Flush.

poker:SpadesCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasSuit ; owl:hasValue poker:Spades ]
        )
    ] ;
    rdfs:label "Spades Card" ;
    rdfs:comment "Card whose suit is Spades." .

poker:HeartsCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasSuit ; owl:hasValue poker:Hearts ]
        )
    ] ;
    rdfs:label "Hearts Card" ;
    rdfs:comment "Card whose suit is Hearts." .

poker:DiamondsCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasSuit ; owl:hasValue poker:Diamonds ]
        )
    ] ;
    rdfs:label "Diamonds Card" ;
    rdfs:comment "Card whose suit is Diamonds." .

poker:ClubsCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasSuit ; owl:hasValue poker:Clubs ]
        )
    ] ;
    rdfs:label "Clubs Card" ;
    rdfs:comment "Card whose suit is Clubs." .

# 13.2 Rank Helper Classes (13 classes)
# XxxRankCard ≡ Card ∩ hasRank.{Xxx}
# Enable owl:qualifiedCardinality over cards of a specific rank.
# Example: >=3 containsCard AceRankCard detects Three of a Kind (Aces).

poker:TwoRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Two ]
        )
    ] ;
    rdfs:label "Two Rank Card" ;
    rdfs:comment "Card whose rank is Two." .

poker:ThreeRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Three ]
        )
    ] ;
    rdfs:label "Three Rank Card" ;
    rdfs:comment "Card whose rank is Three." .

poker:FourRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Four ]
        )
    ] ;
    rdfs:label "Four Rank Card" ;
    rdfs:comment "Card whose rank is Four." .

poker:FiveRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Five ]
        )
    ] ;
    rdfs:label "Five Rank Card" ;
    rdfs:comment "Card whose rank is Five." .

poker:SixRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Six ]
        )
    ] ;
    rdfs:label "Six Rank Card" ;
    rdfs:comment "Card whose rank is Six." .

poker:SevenRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Seven ]
        )
    ] ;
    rdfs:label "Seven Rank Card" ;
    rdfs:comment "Card whose rank is Seven." .

poker:EightRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Eight ]
        )
    ] ;
    rdfs:label "Eight Rank Card" ;
    rdfs:comment "Card whose rank is Eight." .

poker:NineRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Nine ]
        )
    ] ;
    rdfs:label "Nine Rank Card" ;
    rdfs:comment "Card whose rank is Nine." .

poker:TenRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Ten ]
        )
    ] ;
    rdfs:label "Ten Rank Card" ;
    rdfs:comment "Card whose rank is Ten." .

poker:JackRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Jack ]
        )
    ] ;
    rdfs:label "Jack Rank Card" ;
    rdfs:comment "Card whose rank is Jack." .

poker:QueenRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Queen ]
        )
    ] ;
    rdfs:label "Queen Rank Card" ;
    rdfs:comment "Card whose rank is Queen." .

poker:KingRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:King ]
        )
    ] ;
    rdfs:label "King Rank Card" ;
    rdfs:comment "Card whose rank is King." .

poker:AceRankCard a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Card
            [ a owl:Restriction ; owl:onProperty poker:hasRank ; owl:hasValue poker:Ace ]
        )
    ] ;
    rdfs:label "Ace Rank Card" ;
    rdfs:comment "Card whose rank is Ace." .

# 13.3 BestHand by Ranking (10 defined classes)
# XxxBestHand ≡ BestHand ∩ hasHandRanking.{XxxRanking}
# Classify a BestHand already tagged with its ranking individual.

poker:HighCardBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:HighCardRanking ]
        )
    ] ;
    rdfs:label "Best Hand: High Card" ;
    rdfs:comment "BestHand classified as High Card." .

poker:OnePairBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:OnePairRanking ]
        )
    ] ;
    rdfs:label "Best Hand: One Pair" ;
    rdfs:comment "BestHand classified as One Pair." .

poker:TwoPairBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:TwoPairRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Two Pair" ;
    rdfs:comment "BestHand classified as Two Pair." .

poker:ThreeOfAKindBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:ThreeOfAKindRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Three of a Kind" ;
    rdfs:comment "BestHand classified as Three of a Kind." .

poker:StraightBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:StraightRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Straight" ;
    rdfs:comment "BestHand classified as Straight." .

poker:FlushBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:FlushRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Flush" ;
    rdfs:comment "BestHand classified as Flush." .

poker:FullHouseBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:FullHouseRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Full House" ;
    rdfs:comment "BestHand classified as Full House." .

poker:FourOfAKindBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:FourOfAKindRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Four of a Kind" ;
    rdfs:comment "BestHand classified as Four of a Kind." .

poker:StraightFlushBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:StraightFlushRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Straight Flush" ;
    rdfs:comment "BestHand classified as Straight Flush." .

poker:RoyalFlushBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Restriction ; owl:onProperty poker:hasHandRanking ; owl:hasValue poker:RoyalFlushRanking ]
        )
    ] ;
    rdfs:label "Best Hand: Royal Flush" ;
    rdfs:comment "BestHand classified as Royal Flush." .

# 13.4 Royal Flush by Cards Pattern (4 variants)
# RoyalFlushByCardsBestHand ≡ BestHand ∩ unionOf(
#   [10-J-Q-K-A of Spades] ⊔ [10-J-Q-K-A of Hearts] ⊔ ...)
# A reasoner automatically detects the Royal Flush by cards.

poker:RoyalFlushByCardsBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ;
              owl:unionOf (
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TenOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:JackOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:QueenOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:KingOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfSpades ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TenOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:JackOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:QueenOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:KingOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfHearts ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TenOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:JackOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:QueenOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:KingOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfDiamonds ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TenOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:JackOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:QueenOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:KingOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfClubs ]
                )]
              )
            ]
        )
    ] ;
    rdfs:label "Royal Flush by Cards" ;
    rdfs:comment "BestHand with 10-J-Q-K-A of the same suit (4 possible variants, one per suit)." .

# 13.5 Steel Wheel by Cards Pattern (4 variants)
# SteelWheelBestHand: A-2-3-4-5 of the same suit.
# The lowest Straight Flush; the Ace counts as 1.

poker:SteelWheelBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ;
              owl:unionOf (
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfSpades ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfHearts ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfDiamonds ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:AceOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfClubs ]
                )]
              )
            ]
        )
    ] ;
    rdfs:label "Steel Wheel by Cards" ;
    rdfs:comment "BestHand with A-2-3-4-5 of the same suit (low straight flush, 4 variants)." .

# 13.6 Standard Straight Flush by Cards Pattern (32 variants)
# StraightFlushByCardsBestHand: 8 intermediate ranges × 4 suits = 32 variants.
# Excludes Royal Flush (Broadway × 4) and Steel Wheel (Wheel × 4),
# modeled as separate classes in 13.4 and 13.5.

poker:StraightFlushByCardsBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ;
              owl:unionOf (
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfSpades ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfHearts ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfDiamonds ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:TwoOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfClubs ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SevenOfSpades ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SevenOfHearts ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfDiamonds ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SevenOfDiamonds ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:ThreeOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfClubs ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SevenOfClubs ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SevenOfSpades ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:EightOfSpades ]
                )]
                [ a owl:Class ; owl:intersectionOf (
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FourOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:FiveOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SixOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:SevenOfHearts ]
                    [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:hasValue poker:EightOfHearts ]
