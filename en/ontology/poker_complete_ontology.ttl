# 13.7 Four of a Kind by Cards Pattern (13 variants)
# FourOfAKindByCardsBestHand: qualifiedCardinality 4 for each rank.

poker:FourOfAKindByCardsBestHand a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:BestHand
            [ a owl:Class ;
              owl:unionOf (
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:qualifiedCardinality "4"^^xsd:nonNegativeInteger ; owl:onClass poker:TwoRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:qualifiedCardinality "4"^^xsd:nonNegativeInteger ; owl:onClass poker:ThreeRankCard ]
                [ a owl:Restriction ; owl:onProperty poker:containsCard ; owl:qualifiedCardinality "4"^^xsd:nonNegativeInteger ; owl:onClass poker:FourRankCard ]
