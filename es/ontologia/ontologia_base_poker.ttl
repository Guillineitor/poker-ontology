# Posiciones (6 individuos) --------------------------------------------------

poker:CiegaPequena a poker:PosicionCiegaPequena ;
    rdfs:label "Ciega Pequeña" .
poker:CiegaGrande a poker:PosicionCiegaGrande ;
    rdfs:label "Ciega Grande" .
poker:BajoElCanon a poker:PosicionTemprana ;
    rdfs:label "Under the Gun" .
poker:PosicionMediaInd a poker:PosicionMedia ;
    rdfs:label "Posición Media" .
poker:CutOff a poker:PosicionTardia ;
    rdfs:label "Cutoff" .
poker:Boton a poker:PosicionBoton ;
    rdfs:label "Botón" .

# Estructuras de apuesta (3 individuos) --------------------------------------

poker:NLHE a poker:SinLimite ;
    rdfs:label "No Limit Texas Hold'em" .
poker:LHE a poker:ConLimite ;
    rdfs:label "Limit Texas Hold'em" .
poker:PLHE a poker:LimiteBote ;
    rdfs:label "Pot Limit Texas Hold'em" .

# Clasificaciones de mano (10 individuos) ------------------------------------

poker:ClasificacionCartaAlta a poker:CartaAlta ;
    rdfs:label "Clasificación Carta Alta" .
poker:ClasificacionUnPar a poker:UnPar ;
    rdfs:label "Clasificación Un Par" .
poker:ClasificacionDoblePar a poker:DoblePar ;
    rdfs:label "Clasificación Doble Par" .
poker:ClasificacionTrio a poker:Trio ;
    rdfs:label "Clasificación Trío" .
poker:ClasificacionEscalera a poker:Escalera ;
    rdfs:label "Clasificación Escalera" .
poker:ClasificacionColor a poker:Color ;
    rdfs:label "Clasificación Color" .
poker:ClasificacionFullHouse a poker:FullHouse ;
    rdfs:label "Clasificación Full House" .
poker:ClasificacionPoker a poker:Poker ;
    rdfs:label "Clasificación Póker" .
poker:ClasificacionEscaleraColor a poker:EscaleraColor ;
    rdfs:label "Clasificación Escalera de Color" .
poker:ClasificacionEscaleraReal a poker:EscaleraReal ;
    rdfs:label "Clasificación Escalera Real" .

# Cadena de supera (9 relaciones directas → 45 pares inferidos por transitividad)
# Orden de mayor a menor fortaleza:
#   EscaleraReal > EscaleraColor > Poker > FullHouse > Color
#   > Escalera > Trio > DoblePar > UnPar > CartaAlta
# El razonador infiere automáticamente los pares no adyacentes,
# por ejemplo ClasificacionPoker supera ClasificacionUnPar.

poker:ClasificacionEscaleraReal      poker:supera poker:ClasificacionEscaleraColor .
poker:ClasificacionEscaleraColor   poker:supera poker:ClasificacionPoker .
poker:ClasificacionPoker     poker:supera poker:ClasificacionFullHouse .
poker:ClasificacionFullHouse       poker:supera poker:ClasificacionColor .
poker:ClasificacionColor           poker:supera poker:ClasificacionEscalera .
poker:ClasificacionEscalera        poker:supera poker:ClasificacionTrio .
poker:ClasificacionTrio    poker:supera poker:ClasificacionDoblePar .
poker:ClasificacionDoblePar         poker:supera poker:ClasificacionUnPar .
poker:ClasificacionUnPar         poker:supera poker:ClasificacionCartaAlta .

# Axiomas AllDifferent -------------------------------------------------------
# Bajo OWA, dos IRIs distintos podrían referirse al mismo individuo.
# AllDifferent cierra ese mundo para cada grupo, garantizando que el
# razonador los trate como entidades verdaderamente diferentes.

# 4 palos distintos
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:Picas poker:Corazones poker:Diamantes poker:Treboles ) .

# 13 rangos distintos
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:Dos poker:Tres poker:Cuatro poker:Cinco poker:Seis
                          poker:Siete poker:Ocho poker:Nueve poker:Diez poker:Jota
                          poker:Reina poker:Rey poker:As ) .

# 52 cartas distintas
[] a owl:AllDifferent ;
    owl:distinctMembers (
        poker:DosDePicas   poker:TresDePicas   poker:CuatroDePicas   poker:CincoDePicas
        poker:SeisDePicas   poker:SieteDePicas   poker:OchoDePicas  poker:NueveDePicas
        poker:DiezDePicas   poker:JotaDePicas    poker:ReinaDePicas  poker:ReyDePicas
        poker:AsDePicas
        poker:DosDeCorazones   poker:TresDeCorazones   poker:CuatroDeCorazones   poker:CincoDeCorazones
        poker:SeisDeCorazones   poker:SieteDeCorazones   poker:OchoDeCorazones  poker:NueveDeCorazones
        poker:DiezDeCorazones   poker:JotaDeCorazones    poker:ReinaDeCorazones  poker:ReyDeCorazones
        poker:AsDeCorazones
        poker:DosDeDiamantes poker:TresDeDiamantes poker:CuatroDeDiamantes poker:CincoDeDiamantes
        poker:SeisDeDiamantes poker:SieteDeDiamantes poker:OchoDeDiamantes poker:NueveDeDiamantes
        poker:DiezDeDiamantes poker:JotaDeDiamantes  poker:ReinaDeDiamantes poker:ReyDeDiamantes
        poker:AsDeDiamantes
        poker:DosDeTreboles    poker:TresDeTreboles    poker:CuatroDeTreboles    poker:CincoDeTreboles
        poker:SeisDeTreboles    poker:SieteDeTreboles    poker:OchoDeTreboles   poker:NueveDeTreboles
        poker:DiezDeTreboles    poker:JotaDeTreboles     poker:ReinaDeTreboles   poker:ReyDeTreboles
        poker:AsDeTreboles
    ) .

# 6 posiciones distintas
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:CiegaPequena poker:CiegaGrande poker:BajoElCanon
                          poker:PosicionMediaInd poker:CutOff poker:Boton ) .

# 10 clasificaciones de mano distintas
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:ClasificacionCartaAlta poker:ClasificacionUnPar poker:ClasificacionDoblePar
                          poker:ClasificacionTrio poker:ClasificacionEscalera poker:ClasificacionColor
                          poker:ClasificacionFullHouse poker:ClasificacionPoker
                          poker:ClasificacionEscaleraColor poker:ClasificacionEscaleraReal ) .

# 3 estructuras de apuesta distintas
[] a owl:AllDifferent ;
    owl:distinctMembers ( poker:NLHE poker:LHE poker:PLHE ) .


# =============================================================================
# MÓDULO 13 — EXTENSIÓN: CLASIFICADORES DE MANOS (no incluido en esta base)
# =============================================================================
# Esta es la ontología BASE. Los clasificadores concretos (Color, Escalera,
# Trío, etc.) deben implementarse en archivos separados que importen
# esta base y añadan sus propias restricciones owl:equivalentClass.
#
# Ejemplo mínimo de clasificador externo:
#
#   @prefix poker: <http://www.poker-ontology.org/poker#> .
#   @prefix ex: <http://example.org/clasificadores#> .
#
#   <http://example.org/clasificadores>
#       owl:imports <http://www.poker-ontology.org/poker> .
#
#   ex:ColorDiamantes a owl:Class ;
#       rdfs:subClassOf poker:MejorMano ;
#       owl:equivalentClass [
#           owl:intersectionOf (
#               poker:MejorMano
#               [ owl:onProperty poker:contieneCarta ;
#                 owl:allValuesFrom
#                   [ owl:onProperty poker:tienePalo ;
#                     owl:hasValue poker:Diamantes ] ]
#           )
#       ] .
# =============================================================================
