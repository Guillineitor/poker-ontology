poker:SieteDeCorazones a poker:Carta ;
    poker:tienePalo poker:Corazones ; poker:tieneRango poker:Siete ;
    rdfs:label "Siete de Corazones" .
poker:OchoDeCorazones a poker:Carta ;
    poker:tienePalo poker:Corazones ; poker:tieneRango poker:Ocho ;
