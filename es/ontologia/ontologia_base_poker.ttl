# =============================================================================
# Ontología de Póker Texas Hold'em (Español)
# =============================================================================

@prefix : <http://www.poker-ontology.org/poker#> .
@prefix poker: <http://www.poker-ontology.org/poker#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
#
# Propósito
# ---------
# Ontología escrita en Ontology Web Language (OWL) para modelar la estructura y
# las componentes que conforman las partidas de Póker, en particular la variante Texas Hold'em Poker.
# Esta es la ontología base que define sus clases, propiedades e individuos
# fundamentales. No contiene clasificadores para la inferencia de manos. Esos clasificadores se implementan
# como componentes separados que se le pueden agregar a esta ontología base y añaden sus propias
# restricciones owl:equivalentClass.
#
# Open World Assumption (OWA)
# ----------------------------------
# OWL asume que lo que no está afirmado es desconocido, no falso necesariamente.
# Para compensarlo, Palo y Rango se cierran con owl:oneOf (exactamente
# 4 palos y 13 rangos), y los 52 individuos de cartas se declaran
# AllDifferent para que el razonador los trate como entidades distintas (porque
# claramente son cartas distintas entre sí).
# =============================================================================

<http://www.poker-ontology.org/poker>
    rdf:type owl:Ontology ;
    rdfs:label "Ontología de Póker" ;
    rdfs:comment "Ontología OWL 2 DL que modela el juego de Texas Hold'em Poker." ;
    owl:versionInfo "2.0.0" .

# =============================================================================
# Palos y Rangos de las Cartas
# =============================================================================

# Palo y Rango se definen como clases cerradas usando owl:equivalentClass +
# owl:oneOf. Esto es necesario porque, bajo la Suposición de Mundo Abierto,
# OWL admitiría la existencia de un quinto palo no declarado (y evidentemente no existe, 
# pues el póker se juega con baraja inglesa). Con oneOf
# establecemos explícitamente los únicos individuos posibles:
#
#   Palo ≡ { Picas, Corazones, Diamantes, Tréboles }         (exactamente 4 palos)
#   Rango ≡ { Dos, Tres, Cuatro, Cinco, Seis, Siete, 
#           Ocho, Nueve, Diez, Jota, Reina, Rey, As }        (exactamente 13 rangos)

# Definición de la clase Palo.
poker:Palo a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( poker:Picas poker:Corazones poker:Diamantes poker:Treboles )
    ] ;
    rdfs:label "Palo" ;
    rdfs:comment "Palo de una carta. Clase cerrada: exactamente Picas, Corazones, Diamantes y Tréboles." .

# Definición de la clase Rango.
poker:Rango a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( poker:Dos poker:Tres poker:Cuatro poker:Cinco poker:Seis poker:Siete poker:Ocho poker:Nueve poker:Diez poker:Jota poker:Reina poker:Rey poker:As )
    ] ;
    rdfs:label "Rango" ;
    rdfs:comment "Rango de una carta. Clase cerrada: exactamente Dos, Tres, Cuatro, Cinco, Seis, Siete, Ocho, Nueve, Diez, Jota, Reina, Rey y As ." .

# Carta es cualquier carta de la baraja inglesa estándar. Cada carta debe tener
# al menos un palo (tienePalo) y un rango (tieneRango). Las cardinalidades
# exactas se garantizan marcando esas propiedades como FunctionalProperty

# Definición de la clase Carta, con restricciones sobre sus propiedades.
poker:Carta a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:tienePalo ;
        owl:someValuesFrom poker:Palo
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:tieneRango ;
        owl:someValuesFrom poker:Rango
    ] ;
    rdfs:label "Carta" ;
    rdfs:comment "Una carta de la baraja inglesa estándar de 52 cartas." .

# =============================================================================
# Manos y Cartas Comunitarias
# =============================================================================

# Jerarquía de manos:
#
#   Mano
#   ├── CartasPrivadas      Las 2 cartas privadas del jugador
#   ├── CartasComunitarias  Las cartas compartidas por todos
#   │     ├── CartaFlop          Las 3 primeras cartas comunitarias
#   │     ├── CartaTurn          La 4º carta comunitaria
#   │     └── CartaRiver         La 5º y última carta comunitaria
#   └── MejorMano           La mejor combinación de 5 cartas del jugador
#
# Las cardinalidades fijas (2 cartas en CartasPrivadas, 3 en CartaFlop, etc.) se
# expresan con owl:qualifiedCardinality. MejorMano, además, requiere
# tener una clasificación asignada (tieneClasificacion someValuesFrom ClasificacionMano).

# Definición de la clase Mano
poker:Mano a owl:Class ;
    rdfs:label "Mano" ;
    rdfs:comment "Una mano de cartas en el juego." .

# Definición de la clase CartasPrivadas
poker:CartasPrivadas a owl:Class ;
    rdfs:subClassOf poker:Mano ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:contieneCarta ;
        owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Carta
    ] ;
    rdfs:label "Cartas Privadas" ;
    rdfs:comment "Las 2 cartas privadas repartidas a cada jugador." .

# Definición de la clase CartasComunitarias
poker:CartasComunitarias a owl:Class ;
    rdfs:subClassOf poker:Mano ;
    rdfs:label "Cartas Comunitarias" ;
    rdfs:comment "Las cartas comunitarias compartidas por todos los jugadores." .

# Definición de la clase CartaFlop
poker:CartaFlop a owl:Class ;
    rdfs:subClassOf poker:CartasComunitarias ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:contieneCarta ;
        owl:qualifiedCardinality "3"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Carta
    ] ;
    rdfs:label "Carta Flop" ;
    rdfs:comment "Las 3 primeras cartas comunitarias." .

# Definición de la clase CartaTurn
poker:CartaTurn a owl:Class ;
    rdfs:subClassOf poker:CartasComunitarias ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:contieneCarta ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Carta
    ] ;
    rdfs:label "Carta Turn" ;
    rdfs:comment "La 4.ª carta comunitaria." .

# Definición de la clase CartaRiver
poker:CartaRiver a owl:Class ;
    rdfs:subClassOf poker:CartasComunitarias ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:contieneCarta ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Carta
    ] ;
    rdfs:label "Carta River" ;
    rdfs:comment "La 5.ª y última carta comunitaria." .

# Definición de la clase MejorMano
poker:MejorMano a owl:Class ;
    rdfs:subClassOf poker:Mano ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:contieneCarta ;
        owl:qualifiedCardinality "5"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Carta
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty poker:tieneClasificacion ;
        owl:someValuesFrom poker:ClasificacionMano
    ] ;
    rdfs:label "Mejor Mano" ;
    rdfs:comment "La mejor combinación de 5 cartas de un jugador, con su clasificación asignada." .


# =============================================================================
# Clasificación de Manos
# =============================================================================

# Jerarquía de clasificaciones, de menor a mayor fortaleza:
#
#   ClasificacionMano
#   ├── CartaAlta      (1) Carta Alta: Sin combinación; gana la carta más alta
#   ├── Par            (2) Par: Dos cartas del mismo rango
#   ├── DoblePar       (3) Doble Par: Dos pares distintos
#   ├── Trio           (4) Trío: Tres cartas del mismo rango
#   ├── Escalera       (5) Escalera: Cinco cartas consecutivas de distintos palos
#   ├── Color          (6) Color: Cinco cartas del mismo palo
#   ├── FullHouse      (7) FullHouse: Un trío más un par
#   ├── Poker          (8) Póker: Cuatro cartas del mismo rango
#   └── EscaleraColor  (9) Escalera de Color: Cinco cartas consecutivas del mismo palo
#         └── EscaleraReal    Escalera Real: 10-J-Q-K-A del mismo palo (subclase de EscaleraColor)
#
# EscaleraReal es una subclase de EscaleraColor, no una clase independiente, pues es un 
# caso particular de la Escalera de Color. Las 9 clases base son mutuamente disjuntas. 
# Inferencialmente, alguna clasificación puede estar contenida dentro de otra 
# (por ejemplo, un FullHouse es la combinación entre un trío y un par), pero no son subclases 
# entre sí, sino clases disjuntas que se combinan en MejorMano.

# Definición de la clase ClasificacionMano
poker:ClasificacionMano a owl:Class ;
    rdfs:label "Clasificación de Mano" ;
    rdfs:comment "Categoría que describe el valor de una mano de póker." .

# Definición de la clase CartaAlta
poker:CartaAlta a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Carta Alta" ;
    rdfs:comment "Sin combinación; la carta más alta decide el ganador." .

# Definición de la clase Par
poker:Par a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Par" ;
    rdfs:comment "Dos cartas del mismo rango." .

# Definición de la clase DoblePar
poker:DoblePar a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Doble Par" ;
    rdfs:comment "Dos pares de rangos distintos." .

# Definición de la clase Trio
poker:Trio a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Trío" ;
    rdfs:comment "Tres cartas del mismo rango." .

# Definición de la clase Escalera
poker:Escalera a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Escalera" ;
    rdfs:comment "Cinco cartas de rangos consecutivos con distintos palos." .

# Definición de la clase Color
poker:Color a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Color" ;
    rdfs:comment "Cinco cartas del mismo palo." .

# Definición de la clase FullHouse
poker:FullHouse a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Full House" ;
    rdfs:comment "Un trío más un par." .

# Definición de la clase Poker
poker:Poker a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Póker" ;
    rdfs:comment "Cuatro cartas del mismo rango." .

# Definición de la clase EscaleraColor
poker:EscaleraColor a owl:Class ;
    rdfs:subClassOf poker:ClasificacionMano ;
    rdfs:label "Escalera de Color" ;
    rdfs:comment "Cinco cartas consecutivas del mismo palo." .

# Definición de la clase EscaleraReal
poker:EscaleraReal a owl:Class ;
    rdfs:subClassOf poker:EscaleraColor ;
    rdfs:label "Escalera Real" ;
    rdfs:comment "Escalera de color de Diez a As (10-J-Q-K-A del mismo palo). Subclase de EscaleraColor." .


# =============================================================================
# Jugadores, Posiciones y Roles
# =============================================================================

# Repartidor, JugadorCiegaPequena y JugadorCiegaGrande son clases definidas mediante
# owl:equivalentClass. Esto significa que el razonador puede inferir
# automáticamente el rol de un jugador a partir de su posición, sin
# necesidad de declararlo explícitamente:
#
#   Repartidor           ≡ Jugador ∩ tienePosicion.{Boton}
#   JugadorCiegaPequena  ≡ Jugador ∩ tienePosicion.{CiegaPequena}
#   JugadorCiegaGrande   ≡ Jugador ∩ tienePosicion.{CiegaGrande}
#
# Nota sobre heads-up: PosicionBoton NO es disjunta con PosicionCiegaPequena
# porque en una partida de 2 jugadores el Botón es la Ciega Pequena.

# Definición de la clase Jugador
poker:Jugador a owl:Class ;
    rdfs:label "Jugador" ;
    rdfs:comment "Un jugador de póker." .

# Definición de la clase Posicion
poker:Posicion a owl:Class ;
    rdfs:label "Posición" ;
    rdfs:comment "La posición de un jugador en la mesa durante una mano." .

# Definición de la clase PosicionCiegaPequena
poker:PosicionCiegaPequena a owl:Class ;
    rdfs:subClassOf poker:Posicion ;
    rdfs:label "Posición Ciega Pequeña" ;
    rdfs:comment "Posición del jugador que pone la ciega pequeña." .

# Definición de la clase PosicionCiegaGrande
poker:PosicionCiegaGrande a owl:Class ;
    rdfs:subClassOf poker:Posicion ;
    rdfs:label "Posición Ciega Grande" ;
    rdfs:comment "Posición del jugador que pone la ciega grande." .

# Definición de la clase PosicionBoton
poker:PosicionBoton a owl:Class ;
    rdfs:subClassOf poker:Posicion ;
    rdfs:label "Posición del Botón" ;
    rdfs:comment "Posición del botón del repartidor. En heads-up coincide con la ciega pequeña." .

# Clases de rol definidas, donde un razonador las infiere a partir de tienePosicion.

# Definición de la clase Repartidor (Dealer)
poker:Repartidor a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Jugador
            [ a owl:Restriction ; owl:onProperty poker:tienePosicion ; owl:hasValue poker:Boton ]
        )
    ] ;
    rdfs:label "Repartidor" ;
    rdfs:comment "Jugador con el botón del repartidor (dealer). Clase definida: Jugador ∩ tienePosicion.{Boton}." .

# Definición de la clase JugadorCiegaPequena
poker:JugadorCiegaPequena a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Jugador
            [ a owl:Restriction ; owl:onProperty poker:tienePosicion ; owl:hasValue poker:CiegaPequena ]
        )
    ] ;
    rdfs:label "Jugador Ciega Pequeña" ;
    rdfs:comment "Jugador en posición de ciega pequeña. Clase definida: Jugador ∩ tienePosicion.{CiegaPequena}." .

# Definición de la clase JugadorCiegaGrande
poker:JugadorCiegaGrande a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Jugador
            [ a owl:Restriction ; owl:onProperty poker:tienePosicion ; owl:hasValue poker:CiegaGrande ]
        )
    ] ;
    rdfs:label "Jugador Ciega Grande" ;
    rdfs:comment "Jugador en posición de ciega grande. Clase definida: Jugador ∩ tienePosicion.{CiegaGrande}." .


# =============================================================================
# Estructura del juego: Partida y Ronda
# =============================================================================

# Partida es la clase central que une todos los elementos de una mano.
# Sus restricciones estructurales son:
#   - Entre 2 y 10 jugadores (minQC 2, maxQC 10)
#   - Exactamente 1 PreFlop; Flop, Turn, River y Showdown (máximo 1 de cada uno) son opcionales si todos los jugadores se retiran.
#   - Exactamente 3 CartaFlop, 1 CartaTurn y 1 CartaRiver en las cartas comunitarias
#   - Al menos 1 BotePrincipal
#   - Al menos 1 jugador ganador
#
# PreFlop exige que ocurran las acciones PonerCiegaPequena y PonerCiegaGrande.
# Showdown no tiene acciones de apuesta (maxQC 0 sobre Accion).
#
# PartidaHeadsUp es una clase específica: Partida con exactamente 2 jugadores.
# El razonador la infiere automáticamente a partir de la cardinalidad.

# Definición de la clase Partida con sus restricciones estructurales.
# Una partida de Texas Hold'em Poker tiene:
# - Entre 2 y 10 jugadores
# - 1 ronda se puede conformar por las etapas: PreFlop, Flop, Turn, River, Showdown.
# - La etapa PreFlop exige que ocurran las acciones PonerCiegaPequena y PonerCiegaGrande, siendo esta etapa obligatoria siempre en una ronda.
# - Las etapas Flop, Turn y River son opcionales si todos los jugadores se retiran en la etapa de PreFlop, sin embargo deben suceder en orden, es decir, no puede haber Turn sin Flop y no puede haber River sin Flop y Turn.
# - La etapa Showdown exige que ocurran las acciones MostrarMejorMano si o solo si no todos los jugadores se retiraron en la etapa de River.
# - La etapa Showdown no tiene acciones de apuesta (maxQC 0 sobre Accion).
# - Exactamente 3 CartaFlop, 1 CartaTurn y 1 CartaRiver en las cartas comunitarias
# - Al menos 1 BotePrincipal
# - Al menos 1 jugador ganador
poker:Partida a owl:Class ;
    rdfs:label "Partida" ;
    rdfs:comment "Una partida completa de Texas Hold'em Poker." ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneJugador ;
        owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Jugador
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneJugador ;
        owl:maxQualifiedCardinality "10"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Jugador
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneRonda ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:PreFlop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneRonda ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Flop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneRonda ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Turn
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneRonda ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:River
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneRonda ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Showdown
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneCartasComunitarias ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:CartaFlop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneCartasComunitarias ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:CartaTurn
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneCartasComunitarias ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:CartaRiver
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneBote ;
        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:BotePrincipal
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneGanador ;
        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Jugador
    ] .

# Definición de la clase PartidaHeadsUp. 
poker:PartidaHeadsUp a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            poker:Partida
            [ a owl:Restriction ; owl:onProperty poker:tieneJugador ;
              owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
              owl:onClass poker:Jugador ]
        )
    ] ;
    rdfs:label "Partida Heads-Up" ;
    rdfs:comment "Partida entre exactamente 2 jugadores. Clase definida inferida por el razonador a partir de la cardinalidad." .

# Definición de la clase Ronda, con sus subclases para cada etapa del juego.
poker:Ronda a owl:Class ;
    rdfs:label "Ronda" ;
    rdfs:comment "Una ronda de juego dentro de una partida de póker." .

# Definición de la clase PreFlop, con las acciones obligatorias de ciegas.
poker:PreFlop a owl:Class ;
    rdfs:subClassOf poker:Ronda ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneAccion ;
        owl:someValuesFrom poker:PonerCiegaPequena
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneAccion ;
        owl:someValuesFrom poker:PonerCiegaGrande
    ] ;
    rdfs:label "Pre-Flop" ;
    rdfs:comment "Primera ronda de apuestas, antes de las cartas comunitarias. Incluye las ciegas obligatorias." .

# Definición de la clase Flop, con las 3 cartas comunitarias correspondientes.
poker:Flop a owl:Class ;
    rdfs:subClassOf poker:Ronda ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:revelaCartas ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:CartaFlop
    ] ;
    rdfs:label "Flop" ;
    rdfs:comment "Ronda de apuestas tras revelar el Flop." .

# Definición de la clase Turn, con la carta comunitaria correspondiente.
poker:Turn a owl:Class ;
    rdfs:subClassOf poker:Ronda ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:revelaCartas ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:CartaTurn
    ] ;
    rdfs:label "Turn" ;
    rdfs:comment "Ronda de apuestas tras revelar el Turn." .

# Definición de la clase River, con la carta comunitaria correspondiente.
poker:River a owl:Class ;
    rdfs:subClassOf poker:Ronda ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:revelaCartas ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass poker:CartaRiver
    ] ;
    rdfs:label "River" ;
    rdfs:comment "Ronda de apuestas tras revelar el River." .

# Definición de la clase Showdown, sin acciones de apuesta ni cartas reveladas.
poker:Showdown a owl:Class ;
    rdfs:subClassOf poker:Ronda ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:tieneAccion ;
        owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
        owl:onClass poker:Accion
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:revelaCartas ;
        owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
        owl:onClass poker:CartasComunitarias
    ] ;
    rdfs:label "Showdown" ;
    rdfs:comment "Ronda final en la que se comparan las manos. No admite acciones de apuesta ni revela nuevas cartas comunitarias." .


# =============================================================================
# Acciones y Apuestas
# =============================================================================

# Jerarquía de acciones:
#
#   Acción
#   ├── Retirar                       Retirarse de la mano
#   ├── Pasar                         Pasar sin apostar (solo si no hay apuesta previa)
#   ├── Igualar                       Igualar la apuesta actual
#   ├── Apostar                       Abrir una apuesta 
#   ├── Subir                         Subir una apuesta existente
#   ├── AllIn                         Apostar todas las fichas (clase que se combina con Apostar/Igualar/Subir)
#   │     ├── AllInApostar            All-In como apuesta inicial
#   │     ├── AllInIgualar            All-In igualando
#   │     └── AllInSubir              All-In subiendo la apuesta
#   └── PonerCiega                    Ciega obligatoria (no es una acción voluntaria)
#         ├── PonerCiegaPequena       Puesta por el JugadorCiegaPequena en el PreFlop
#         └── PonerCiegaGrande        Puesta por el JugadorCiegaGrande en el PreFlop
#
# All-In no es disjunto con Apostar, Igualar ni Subir porque un All-In siempre
# es simultáneamente uno de esos tres tipos de apuesta.
#
# La restricción allValuesFrom en Accion.realizadaEn garantiza que las
# acciones solo pueden ocurrir en rondas de apuesta (nunca en Showdown).

# Definición de la clase Acción.
poker:Accion a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:realizadaEn ;
        owl:allValuesFrom [
            a owl:Class ;
            owl:unionOf ( poker:PreFlop poker:Flop poker:Turn poker:River )
        ]
    ] ;
    rdfs:label "Acción" ;
    rdfs:comment "Acción realizada por un jugador durante una ronda de apuestas." .

# Definición de la clase Retirar.
poker:Retirar a owl:Class ;
    rdfs:subClassOf poker:Accion ;
    rdfs:label "Retirada" ;
    rdfs:comment "Retirarse de la mano, abandonando las fichas apostadas." .

# Definición de la clase Pasar.
poker:Pasar a owl:Class ;
    rdfs:subClassOf poker:Accion ;
    rdfs:label "Pasar" ;
    rdfs:comment "Pasar el turno sin apostar, disponible solo cuando no hay apuesta previa." .

# Definición de la clase Igualar.
poker:Igualar a owl:Class ;
    rdfs:subClassOf poker:Accion ;
    rdfs:label "Igualar" ;
    rdfs:comment "Igualar la apuesta actual para continuar en la mano." .

# Definición de la clase Apostar.
poker:Apostar a owl:Class ;
    rdfs:subClassOf poker:Accion ;
    rdfs:label "Apostar" ;
    rdfs:comment "Realizar la primera apuesta de una calle." .

# Definición de la clase Subir.
poker:Subir a owl:Class ;
    rdfs:subClassOf poker:Accion ;
    rdfs:label "Subir" ;
    rdfs:comment "Aumentar una apuesta ya existente en la misma calle." .

# Definición de la clase All-In, que se combina con Apostar, Igualar o Subir.
poker:AllIn a owl:Class ;
    rdfs:subClassOf poker:Accion ;
    rdfs:label "All-In" ;
    rdfs:comment "Apostar la totalidad de las fichas disponibles. Siempre es también un Bet, Call o Raise." .

# Definición de las clases específicas de All-In según su función en la apuesta.
# Definición de la clase AllInApostar.
poker:AllInApostar a owl:Class ;
    rdfs:subClassOf poker:AllIn , poker:Apostar ;
    rdfs:label "All-In Apostar" ;
    rdfs:comment "All-in que abre la apuesta en la calle." .

# Definición de la clase AllInIgualar.
poker:AllInIgualar a owl:Class ;
    rdfs:subClassOf poker:AllIn , poker:Igualar ;
    rdfs:label "All-In Igualar" ;
    rdfs:comment "All-in que iguala la apuesta actual." .

# Definición de la clase AllInSubir.
poker:AllInSubir a owl:Class ;
    rdfs:subClassOf poker:AllIn , poker:Subir ;
    rdfs:label "All-In Subir" ;
    rdfs:comment "All-in que sube la apuesta actual." .

# Definición de la clase PonerCiega, con sus subclases para ciega pequeña y grande.
poker:PonerCiega a owl:Class ;
    rdfs:subClassOf poker:Accion ;
    rdfs:label "Poner Ciega" ;
    rdfs:comment "Apuesta de ciega obligatoria, no voluntaria. Disjunta con todas las acciones voluntarias." .

# Definición de la clase PonerCiegaPequena.
poker:PonerCiegaPequena a owl:Class ;
    rdfs:subClassOf poker:PonerCiega ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:realizadaEn ;
        owl:someValuesFrom poker:PreFlop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:realizadaPor ;
        owl:someValuesFrom poker:JugadorCiegaPequena
    ] ;
    rdfs:label "Poner Ciega Pequeña" ;
    rdfs:comment "Ciega pequeña obligatoria, pagada por el JugadorCiegaPequena en el PreFlop." .

# Definición de la clase PonerCiegaGrande.
poker:PonerCiegaGrande a owl:Class ;
    rdfs:subClassOf poker:PonerCiega ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:realizadaEn ;
        owl:someValuesFrom poker:PreFlop
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ; owl:onProperty poker:realizadaPor ;
        owl:someValuesFrom poker:JugadorCiegaGrande
    ] ;
    rdfs:label "Poner Ciega Grande" ;
    rdfs:comment "Ciega grande obligatoria, pagada por el JugadorCiegaGrande en el PreFlop." .


# =============================================================================
# Bote y Estructura de Apuesta
# =============================================================================

# Jerarquía de botes:
#
#   Bote
#   ├── BotePrincipal    Bote principal, siempre presente (al menos 1 por partida)
#   └── BoteSecundario   Bote secundario, creado cuando un jugador va All-In por
#                    menos del total apostado. Cada BoteSecundario tiene un número de
#                    orden (secuenciaBote) y un conjunto de jugadores elegibles.
#
# BotePrincipal y BoteSecundario son disjuntos.
#
# Estructuras de apuesta disponibles:
#   SinLimite   Sin límite de apuesta; se puede apostar todo.
#   ConLimite   Tamaño de apuesta fijo.
#   LimiteBote  La apuesta máxima es el tamaño del bote en ese momento.

# Definición de la clase Bote, con sus subclases para bote principal y secundario.
poker:Bote a owl:Class ;
    rdfs:label "Bote" ;
    rdfs:comment "El conjunto de fichas en juego durante una mano." .

# Definición de la clase BotePrincipal.
poker:BotePrincipal a owl:Class ;
    rdfs:subClassOf poker:Bote ;
    rdfs:label "Bote Principal" ;
    rdfs:comment "Bote principal de la partida, al que pueden optar todos los jugadores activos." .

# Definición de la clase BoteSecundario.
poker:BoteSecundario a owl:Class ;
    rdfs:subClassOf poker:Bote ;
    rdfs:label "Bote Secundario" ;
    rdfs:comment "Bote adicional creado cuando un jugador va all-in por menos del total apostado." .

# Definición de la clase EstructuraApuesta, con sus subclases para cada tipo de estructura.
poker:EstructuraApuesta a owl:Class ;
    rdfs:label "Estructura de Apuesta" ;
    rdfs:comment "Tipo de estructura que regula los límites y el tamaño de las apuestas." .

# Definición de la clase SinLimite.
poker:SinLimite a owl:Class ;
    rdfs:subClassOf poker:EstructuraApuesta ;
    rdfs:label "Sin Límite" ;
    rdfs:comment "Sin límite de apuesta: un jugador puede apostar todas sus fichas en cualquier momento." .

# Definición de la clase ConLimite.
poker:ConLimite a owl:Class ;
    rdfs:subClassOf poker:EstructuraApuesta ;
    rdfs:label "Con Límite" ;
    rdfs:comment "Las apuestas y subidas tienen un tamaño fijo predefinido por calle." .

# Definición de la clase LimiteBote.
poker:LimiteBote a owl:Class ;
    rdfs:subClassOf poker:EstructuraApuesta ;
    rdfs:label "Límite del Bote" ;
    rdfs:comment "La apuesta máxima es el tamaño actual del bote." .


# =============================================================================
# Propiedades de Objeto
# =============================================================================

# --- Propiedades de Carta (Carta → Palo / Rango) ----------------------------
#
# tienePalo y tieneRango son FunctionalProperty: cada carta tiene exactamente
# un palo y un rango. Esto, combinado con owl:oneOf en Palo y Rango,
# garantiza la unicidad de cada carta.
# contieneCarta relaciona cualquier mano con las cartas que contiene.

# Definición de la propiedad tienePalo.
poker:tienePalo a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Carta ;
    rdfs:range poker:Palo ;
    rdfs:label "Tiene Palo" ;
    rdfs:comment "Asocia una carta con su palo. Funcional: cada carta tiene exactamente un palo." .

# Definición de la propiedad tieneRango.
poker:tieneRango a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Carta ;
    rdfs:range poker:Rango ;
    rdfs:label "Tiene Rango" ;
    rdfs:comment "Asocia una carta con su rango. Funcional: cada carta tiene exactamente un rango." .

# Definición de la propiedad contieneCarta.
poker:contieneCarta a owl:ObjectProperty ;
    rdfs:domain poker:Mano ;
    rdfs:range poker:Carta ;
    rdfs:label "Contiene Carta" ;
    rdfs:comment "Relaciona una mano con cada una de las cartas que la componen." .

# Definición de la propiedad tieneRangoSiguiente.
poker:tieneRangoSiguiente a owl:ObjectProperty ;
    rdfs:domain poker:Rango ;
    rdfs:range poker:Rango ;
    rdfs:label "Tiene Rango Siguiente" ;
    rdfs:comment "Indica qué rango le sigue inmediatamente en la secuencia. Forma un ciclo cerrado (Rey → As → Dos) para representar la naturaleza circular de la baraja. No es una propiedad transitiva ya que colapsaría todos los rangos en uno solo." .

# --- Propiedades de Mano (Jugador ↔ Mano) ----------------------------------
#
# tieneCartasPrivadas es FunctionalProperty e InverseFunctionalProperty: cada
# jugador tiene un único CartasPrivadas y cada CartasPrivadas pertenece a un solo
# jugador. Esta bidireccionalidad evita ambigüedades.
# tieneMejorMano y tieneClasificacion son Functional: un jugador tiene una sola
# mejor mano y esa mano tiene una sola clasificación.

# Definición de la propiedad tieneCartasPrivadas.
poker:tieneCartasPrivadas a owl:ObjectProperty , owl:FunctionalProperty , owl:InverseFunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range poker:CartasPrivadas ;
    rdfs:label "Tiene Cartas Privadas" ;
    rdfs:comment "Asocia un jugador con sus 2 cartas privadas. Funcional e InverseFuncional: la relación es biyectiva." .

# Definición de la propiedad tieneMejorMano.
poker:tieneMejorMano a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range poker:MejorMano ;
    rdfs:label "Tiene Mejor Mano" ;
    rdfs:comment "Asocia un jugador con su mejor combinación de 5 cartas." .

# Definición de la propiedad tieneClasificacion.
poker:tieneClasificacion a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:MejorMano ;
    rdfs:range poker:ClasificacionMano ;
    rdfs:label "Tiene Clasificación de Mano" ;
    rdfs:comment "Asocia una mejor mano con su categoría de clasificación. Funcional: una mano tiene una sola categoría." .

# Definición de la propiedad repartidaA.
poker:repartidaA a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Carta ;
    rdfs:range poker:Jugador ;
    rdfs:label "Es Repartida A" ;
    rdfs:comment "Indica a qué jugador fue repartida una carta (en particular, las cartas privadas)." .

# --- Propiedades inversas (Partida ↔ Jugador / Accion ↔ Ronda) ---------------
#
# Los pares tieneJugador/participaEn, realizaAccion/realizadaPor y
# realizadaEn/tieneAccion son inversos entre sí. Declarar la inversión
# permite al razonador derivar una dirección a partir de la otra.
# tieneBoteSecundario es subPropertyOf tieneBote: todo bote secundario es también un bote.

# Definición de la propiedad tieneJugador.
poker:tieneJugador a owl:ObjectProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range poker:Jugador ;
    owl:inverseOf poker:participaEn ;
    rdfs:label "Tiene Jugador" ;
    rdfs:comment "Relaciona una partida con cada uno de sus jugadores." .

# Definición de la propiedad participaEn.
poker:participaEn a owl:ObjectProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range poker:Partida ;
    owl:inverseOf poker:tieneJugador ;
    rdfs:label "Participa En" ;
    rdfs:comment "Inversa de tieneJugador: relaciona un jugador con la partida en la que juega." .

# Definición de la propiedad tieneGanador.
poker:tieneGanador a owl:ObjectProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range poker:Jugador ;
    rdfs:label "Tiene Ganador" ;
    rdfs:comment "Relaciona una partida con el o los jugadores que la ganan." .

# Definición de la propiedad tieneRonda.
poker:tieneRonda a owl:ObjectProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range poker:Ronda ;
    rdfs:label "Tiene Ronda" ;
    rdfs:comment "Relaciona una partida con cada una de sus rondas de juego." .

# Definición de la propiedad tieneBote.
poker:tieneBote a owl:ObjectProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range poker:Bote ;
    rdfs:label "Tiene Bote" ;
    rdfs:comment "Relaciona una partida con un bote (principal o secundario)." .

# Definición de la propiedad tieneBoteSecundario
poker:tieneBoteSecundario a owl:ObjectProperty ;
    rdfs:subPropertyOf poker:tieneBote ;
    rdfs:domain poker:Partida ;
    rdfs:range poker:BoteSecundario ;
    rdfs:label "Tiene Bote Secundario" ;
    rdfs:comment "Subpropiedad de tieneBote. Relaciona una partida con sus botes secundarios." .

# Definición de la propiedad tieneCartasComunitarias.
poker:tieneCartasComunitarias a owl:ObjectProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range poker:CartasComunitarias ;
    rdfs:label "Tiene Cartas Comunitarias" ;
    rdfs:comment "Relaciona una partida con sus cartas comunitarias (que hay en Flop, Turn y River)." .

# Definición de la propiedad revelaCartas.
poker:revelaCartas a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Ronda ;
    rdfs:range poker:CartasComunitarias ;
    rdfs:label "Revela Cartas" ;
    rdfs:comment "Relaciona una ronda con el grupo de cartas comunitarias que se revelan en ella. Funcional: cada ronda revela exactamente un grupo." .

# Definición de la propiedad realizaAccion.
poker:realizaAccion a owl:ObjectProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range poker:Accion ;
    owl:inverseOf poker:realizadaPor ;
    rdfs:label "Realiza Acción" ;
    rdfs:comment "Relaciona un jugador con una acción que ejecuta." .

# Definición de la propiedad realizadaPor.
poker:realizadaPor a owl:ObjectProperty ;
    rdfs:domain poker:Accion ;
    rdfs:range poker:Jugador ;
    owl:inverseOf poker:realizaAccion ;
    rdfs:label "Realizada Por" ;
    rdfs:comment "Inversa de realizaAccion: indica qué jugador ejecutó una acción." .

# Definición de la propiedad realizadaEn.
poker:realizadaEn a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Accion ;
    rdfs:range poker:Ronda ;
    owl:inverseOf poker:tieneAccion ;
    rdfs:label "Realizada En" ;
    rdfs:comment "Indica en qué ronda ocurrió una acción. Funcional: cada acción pertenece a una sola ronda." .

# Definición de la propiedad tieneAccion.
poker:tieneAccion a owl:ObjectProperty ;
    rdfs:domain poker:Ronda ;
    rdfs:range poker:Accion ;
    owl:inverseOf poker:realizadaEn ;
    rdfs:label "Tiene Acción" ;
    rdfs:comment "Inversa de realizadaEn: relaciona una ronda con las acciones que ocurren en ella." .

# Definición de la propiedad tienePosicion.
poker:tienePosicion a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range poker:Posicion ;
    rdfs:label "Tiene Posición" ;
    rdfs:comment "Relaciona un jugador con su posición en la mesa durante la mano." .

# Definición de la propiedad usaEstructura.
poker:usaEstructura a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range poker:EstructuraApuesta ;
    rdfs:label "Usa Estructura" ;
    rdfs:comment "Indica la estructura de apuesta de la partida. Funcional: una partida usa una sola estructura." .

# Definición de la propiedad ganaMano.
poker:ganaMano a owl:ObjectProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range poker:MejorMano ;
    rdfs:label "Gana Mano" ;
    rdfs:comment "Relaciona un jugador con la mejor mano con la que ganó una partida." .

# --- Propiedad supera (TransitiveProperty) ---------------------------------
#
# supera ordena las clasificaciones de mayor a menor fortaleza. Al ser
# transitiva, el razonador deriva automáticamente todas las comparaciones
# indirectas: basta declarar 9 relaciones directas para obtener los
# 45 pares completos. Ejemplo: si ClasificacionEscaleraReal supera ClasificacionEscaleraColor y
# ClasificacionEscaleraColor supera ClasificacionPoker, el razonador infiere que
# ClasificacionEscaleraReal supera ClasificacionPoker sin declaración adicional.

# Definición de la propiedad supera 
poker:supera a owl:ObjectProperty , owl:TransitiveProperty ;
    rdfs:domain poker:ClasificacionMano ;
    rdfs:range poker:ClasificacionMano ;
    rdfs:label "Supera" ;
    rdfs:comment "Indica que una clasificación de mano supera a otra. Transitiva: el razonador cierra el orden completo." .

# Definición de la propiedad elegibleParaBote.
poker:elegibleParaBote a owl:ObjectProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range poker:Bote ;
    rdfs:label "Elegible Para Bote" ;
    rdfs:comment "Indica que un jugador tiene derecho a ganar un bote determinado (relevante para botes secundarios)." .


# =============================================================================
# Propiedades de datos
# =============================================================================

# Las propiedades de datos registran valores escalares asociados a los
# individuos del dominio. OWL no realiza cálculos: los valores se registran
# como hechos y la lógica de evaluación (sumas, comparaciones) se implementa
# externamente, por ejemplo con SPARQL o Python.
#
# Las propiedades marcadas como FunctionalProperty garantizan que cada
# individuo tiene como máximo un valor para esa propiedad.

# Definición de la propiedad tieneValorRango.
poker:tieneValorRango a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Rango ;
    rdfs:range xsd:integer ;
    rdfs:label "Tiene Valor De Rango" ;
    rdfs:comment "Valor numérico del rango (2 para Dos, 14 para As)." .

# Definición de la propiedad tieneValorRangoBajo.
poker:tieneValorRangoBajo a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain [
        a owl:Class ;
        owl:oneOf ( poker:As )
    ] ;
    rdfs:range xsd:integer ;
    rdfs:label "Tiene Valor De Rango Bajo" ;
    rdfs:comment "Valor alternativo bajo del As (= 1) para la escalera baja A-2-3-4-5 (Wheel). Restringido exclusivamente al As." .

# Definición de la propiedad tieneConteoFichas.
poker:tieneConteoFichas a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range xsd:integer ;
    rdfs:label "Tiene Conteo De Fichas" ;
    rdfs:comment "Número de fichas actuales del jugador." .

# Definición de la propiedad tieneMontoApuesta.
poker:tieneMontoApuesta a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Accion ;
    rdfs:range xsd:decimal ;
    rdfs:label "Tiene Monto De Apuesta" ;
    rdfs:comment "Cantidad de fichas apostadas en una acción concreta." .

# Definición de la propiedad tieneTamañoBote.
poker:tieneTamanoBote a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Bote ;
    rdfs:range xsd:decimal ;
    rdfs:label "Tiene Tamaño Del Bote" ;
    rdfs:comment "Total de fichas acumuladas en el bote." .

# Definición de la propiedad esCiega
poker:esCiega a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range xsd:boolean ;
    rdfs:label "Es Ciega" ;
    rdfs:comment "Verdadero si el jugador ocupa una posición de ciega (ciega pequeña o ciega grande)." .

# Definición de la propiedad estaAllIn.
poker:estaAllIn a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range xsd:boolean ;
    rdfs:label "Está All-In" ;
    rdfs:comment "Verdadero si el jugador ha apostado todas sus fichas (estado all-in)." .

# Definición de la propiedad seRetiro.
poker:seRetiro a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range xsd:boolean ;
    rdfs:label "Se Retiró" ;
    rdfs:comment "Verdadero si el jugador se ha retirado en la mano actual." .

# Definición de la propiedad nombreJugador.
poker:nombreJugador a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range xsd:string ;
    rdfs:label "Nombre Del Jugador" ;
    rdfs:comment "Nombre o alias del jugador." .

# Definición de la propiedad numeroAsiento.
poker:numeroAsiento a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Jugador ;
    rdfs:range xsd:integer ;
    rdfs:label "Número De Asiento" ;
    rdfs:comment "Número de asiento del jugador en la mesa (entre 1 y 10)." .

# Definición de la propiedad idPartida.
poker:idPartida a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range xsd:string ;
    rdfs:label "ID de Partida" ;
    rdfs:comment "Identificador único de la partida." .

# Definición de la propiedad numeroMano.
poker:numeroMano a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:Partida ;
    rdfs:range xsd:integer ;
    rdfs:label "Número De Mano" ;
    rdfs:comment "Número secuencial de la mano dentro de la sesión." .

# Definición de la propiedad secuenciaBote.
poker:secuenciaBote a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain poker:BoteSecundario ;
    rdfs:range xsd:integer ;
    rdfs:label "Secuencia Del Bote" ;
    rdfs:comment "Número de orden del bote secundario (1 para el primero creado, 2 para el segundo, etc.)." .


# =============================================================================
# Axiomas Estructurales y Restricciones de Disyunción
# =============================================================================

# Estos axiomas garantizan la consistencia global de la ontología.
# Si se viola alguno, por ejemplo, clasificando algo como BotePrincipal y BoteSecundario
# a la vez, un razonador como HermiT o Pellet detectará la inconsistencia.

# Las 9 clases base de ClasificacionMano son mutuamente disjuntas.
# EscaleraReal queda excluido porque es subclase de EscaleraColor, no independiente.
[] a owl:AllDisjointClasses ;
    owl:members ( poker:CartaAlta poker:Par poker:DoblePar poker:Trio
                  poker:Escalera poker:Color poker:FullHouse poker:Poker
                  poker:EscaleraColor ) .

# Una ronda no puede ser dos tipos distintos al mismo tiempo.
[] a owl:AllDisjointClasses ;
    owl:members ( poker:PreFlop poker:Flop poker:Turn poker:River poker:Showdown ) .

# Las acciones voluntarias base son mutuamente disjuntas.
# AllIn queda fuera porque es una clase compuesta que coexiste con Apostar, Igualar o Subir.
[] a owl:AllDisjointClasses ;
    owl:members ( poker:Retirar poker:Pasar poker:Igualar poker:Apostar poker:Subir ) .

# PonerCiega (ciega obligatoria) es disjunta de todas las acciones voluntarias.
poker:PonerCiega owl:disjointWith poker:Retirar .
poker:PonerCiega owl:disjointWith poker:Pasar .
poker:PonerCiega owl:disjointWith poker:Igualar .
poker:PonerCiega owl:disjointWith poker:Apostar .
poker:PonerCiega owl:disjointWith poker:Subir .

# Las tres estructuras de apuesta son mutuamente exclusivas.
[] a owl:AllDisjointClasses ;
    owl:members ( poker:SinLimite poker:ConLimite poker:LimiteBote ) .

# Flop, Turn y River son rondas distintas; nunca se solapan.
[] a owl:AllDisjointClasses ;
    owl:members ( poker:Flop poker:Turn poker:River ) .

# CartaFlop, CartaTurn y CartaRiver son grupos de cartas comunitarias distintos; nunca se solapan.
[] a owl:AllDisjointClasses ;
    owl:members ( poker:CartaFlop poker:CartaTurn poker:CartaRiver ) .

# Un bote es principal o secundario, nunca los dos.
poker:BotePrincipal owl:disjointWith poker:BoteSecundario .

# Disyunciones de posición.
# PosicionCiegaGrande es siempre exclusiva con todas las demás posiciones.
# PosicionBoton NO es disjunta con PosicionCiegaPequena: en heads-up (2 jugadores)
# el botón ocupa simultáneamente la posición de Small Blind.

poker:PosicionCiegaGrande owl:disjointWith poker:PosicionCiegaPequena .
poker:PosicionCiegaGrande owl:disjointWith poker:PosicionBoton .

# NOTA: PosicionBoton NO siempre es disjunta con PosicionCiegaPequena (coinciden en heads-up)


# =============================================================================
# Individuos (ABox)
# =============================================================================

# La ABox define los individuos concretos del dominio.
# Total: 85 individuos
#    4  palos (Palo)                       cerrados por owl:oneOf en la TBox
#   13  rangos (Rango)                     el As tiene valor dual: 14 (alto) y 1 (bajo)
#   52  cartas (Carta)                     13 rangos × 4 palos
#    3  posiciones (Posicion)
#    3  estructuras de apuesta (EstructuraApuesta)
#   10  clasificaciones de mano (ClasificacionMano), incluyendo EscaleraReal

# Palos (4 individuos) -------------------------------------------------------

poker:Picas a poker:Palo ;
    rdfs:label "Picas" .
poker:Corazones a poker:Palo ;
    rdfs:label "Corazones" .
poker:Diamantes a poker:Palo ;
    rdfs:label "Diamantes" .
poker:Treboles a poker:Palo ;
    rdfs:label "Tréboles" .

# Rangos (13 individuos) -----------------------------------------------------
# Los valores de tieneValorRango van de 2 (Dos) a 14 (As).
# El As tiene además tieneValorRangoBajo = 1 para la escalera baja A-2-3-4-5
# (conocida como 'rueda'). OWL no realiza aritmética; estos valores los
# consume la lógica externa (SPARQL, Python) para evaluar manos.

poker:Dos a poker:Rango ;
    poker:tieneValorRango 2 ;
    rdfs:label "Dos" .
poker:Tres a poker:Rango ;
    poker:tieneValorRango 3 ;
    rdfs:label "Tres" .
poker:Cuatro a poker:Rango ;
    poker:tieneValorRango 4 ;
    rdfs:label "Cuatro" .
poker:Cinco a poker:Rango ;
    poker:tieneValorRango 5 ;
    rdfs:label "Cinco" .
poker:Seis a poker:Rango ;
    poker:tieneValorRango 6 ;
    rdfs:label "Seis" .
poker:Siete a poker:Rango ;
    poker:tieneValorRango 7 ;
    rdfs:label "Siete" .
poker:Ocho a poker:Rango ;
    poker:tieneValorRango 8 ;
    rdfs:label "Ocho" .
poker:Nueve a poker:Rango ;
    poker:tieneValorRango 9 ;
    rdfs:label "Nueve" .
poker:Diez a poker:Rango ;
    poker:tieneValorRango 10 ;
    rdfs:label "Diez" .
poker:Jota a poker:Rango ;
    poker:tieneValorRango 11 ;
    rdfs:label "Jota" .
poker:Reina a poker:Rango ;
    poker:tieneValorRango 12 ;
    rdfs:label "Reina" .
poker:Rey a poker:Rango ;
    poker:tieneValorRango 13 ;
    rdfs:label "Rey" .
poker:As a poker:Rango ;
    poker:tieneValorRango 14 ;
    poker:tieneValorRangoBajo 1 ;
    rdfs:label "As" .

# Cadena estática de rangos para inferencia semántica.
poker:As poker:tieneRangoSiguiente poker:Dos .
poker:Dos poker:tieneRangoSiguiente poker:Tres .
poker:Tres poker:tieneRangoSiguiente poker:Cuatro .
poker:Cuatro poker:tieneRangoSiguiente poker:Cinco .
poker:Cinco poker:tieneRangoSiguiente poker:Seis .
poker:Seis poker:tieneRangoSiguiente poker:Siete .
poker:Siete poker:tieneRangoSiguiente poker:Ocho .
poker:Ocho poker:tieneRangoSiguiente poker:Nueve .
poker:Nueve poker:tieneRangoSiguiente poker:Diez .
poker:Diez poker:tieneRangoSiguiente poker:Jota .
poker:Jota poker:tieneRangoSiguiente poker:Reina .
poker:Reina poker:tieneRangoSiguiente poker:Rey .
poker:Rey poker:tieneRangoSiguiente poker:As .

# Cartas (52 individuos) -----------------------------------------------------
# Convención de nombres: {Rango}De{Palo}  (ej. AsDePicas, ReyDeCorazones).
# Cada carta declara explícitamente tienePalo y tieneRango. Esto permite consultas
# SPARQL precisas y habilita el axioma AllDifferent del final del módulo.

# Carta con el Palo de Picas.

poker:DosDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Dos ;
    rdfs:label "Dos de Picas" .
poker:TresDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Tres ;
    rdfs:label "Tres de Picas" .
poker:CuatroDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Cuatro ;
    rdfs:label "Cuatro de Picas" .
poker:CincoDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Cinco ;
    rdfs:label "Cinco de Picas" .
poker:SeisDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Seis ;
    rdfs:label "Seis de Picas" .
poker:SieteDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Siete ;
    rdfs:label "Siete de Picas" .
poker:OchoDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Ocho ;
    rdfs:label "Ocho de Picas" .
poker:NueveDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Nueve ;
    rdfs:label "Nueve de Picas" .
poker:DiezDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Diez ;
    rdfs:label "Diez de Picas" .
poker:JotaDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Jota ;
    rdfs:label "Jota de Picas" .
poker:ReinaDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Reina ;
    rdfs:label "Reina de Picas" .
poker:ReyDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:Rey ;
    rdfs:label "Rey de Picas" .
poker:AsDePicas a poker:Carta ;
    poker:tienePalo poker:Picas ; poker:tieneRango poker:As ;
    rdfs:label "As de Picas" .

