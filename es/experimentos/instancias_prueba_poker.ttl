# =============================================================================
# Instancias de Prueba — Ontología de Póker Texas Hold'em
# =============================================================================
#
# Generado por : generar_instancias_prueba.py
# Fecha        : 2026-04-27
# Perfil OWL   : OWL 2 DL
# Espacio de ns: http://www.poker-ontology.org/pruebas#
#
# Propósito
# ---------
# Una instancia representativa por clasificación de mano para verificar
# que los clasificadores infieren correctamente cada categoría.
# Incluye casos borde: rueda (escalera baja), color con As bajo,
# y la rueda como EscaleraColor.
#
# Total de instancias: 13
#   Clasificaciones cubiertas: CartaAlta, Par, DoblePar, Trío, Escalera (×2),
#   Color (×2), FullHouse, Póker, EscaleraColor (×2), EscaleraReal
#
# Cómo usar
# ---------
# 1. Cargar en Protégé junto con la ontología base y los clasificadores.
# 2. Ejecutar el razonador (HermiT o Pellet).
# 3. Verificar que cada instancia queda clasificada bajo la clase esperada.
# =============================================================================

@prefix poker: <http://www.poker-ontology.org/poker#> .
@prefix test:  <http://www.poker-ontology.org/pruebas#> .
@prefix cls:   <http://www.poker-ontology.org/clasificadores#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://www.poker-ontology.org/pruebas>
    a owl:Ontology ;
    owl:imports <http://www.poker-ontology.org/poker> ;
    rdfs:label "Instancias de Prueba — Clasificadores de Mano" ;
    rdfs:comment "Una MejorMano representativa por clasificación, generada automáticamente." ;
    owl:versionInfo "1.0.0" .

# --- Carta Alta: A-K-Q-J-9 (mixtos) ---
# Caso típico de Carta Alta: cinco rangos distintos, palos distintos, sin consecutivos completos.

test:Jugador_ManoCartaAlta_01 a poker:Jugador ;
    rdfs:label "Carta Alta: A-K-Q-J-9 (mixtos) — Jugador" .

test:ManoCartaAlta_01 a poker:MejorMano , poker:CartaAlta ;
    rdfs:label "Carta Alta: A-K-Q-J-9 (mixtos)" ;
    rdfs:comment "Caso típico de Carta Alta: cinco rangos distintos, palos distintos, sin consecutivos completos." ;
    poker:tieneClasificacion poker:ClasificacionCartaAlta ;
    poker:contieneCarta poker:AsDePicas ;
    poker:contieneCarta poker:ReyDeCorazones ;
    poker:contieneCarta poker:ReinaDeDiamantes ;
    poker:contieneCarta poker:JotaDeTreboles ;
    poker:contieneCarta poker:NueveDePicas ;
    poker:tieneMejorMano test:Jugador_ManoCartaAlta_01 .

test:Jugador_ManoCartaAlta_01 poker:tieneMejorMano test:ManoCartaAlta_01 .

# --- Par: A-A-K-Q-J (par de Ases) ---
