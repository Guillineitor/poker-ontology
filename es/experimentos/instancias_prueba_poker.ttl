    poker:contieneCarta poker:DosDePicas ;
    poker:contieneCarta poker:TresDeDiamantes ;
    poker:contieneCarta poker:CuatroDeTreboles ;
    poker:contieneCarta poker:CincoDePicas ;
    poker:tieneMejorMano test:Jugador_ManoEscalera_Rueda_01 .

