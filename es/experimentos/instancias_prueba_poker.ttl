test:Jugador_ManoPar_01 a poker:Jugador ;
    rdfs:label "Par: A-A-K-Q-J (par de Ases) — Jugador" .

test:ManoPar_01 a poker:MejorMano , poker:Par ;
    rdfs:label "Par: A-A-K-Q-J (par de Ases)" ;
    rdfs:comment "Par de Ases con kickers Rey, Reina, Jota." ;
    poker:tieneClasificacion poker:ClasificacionPar ;
