    poker:contieneCarta poker:ReyDeDiamantes ;
    poker:contieneCarta poker:ReinaDeTreboles ;
    poker:contieneCarta poker:JotaDePicas ;
    poker:tieneMejorMano test:Jugador_ManoPar_01 .

test:Jugador_ManoPar_01 poker:tieneMejorMano test:ManoPar_01 .

