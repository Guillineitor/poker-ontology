        [ a owl:Restriction ; owl:onProperty cls:tieneRangoDelPar ; owl:hasValue poker:As ]
        [ a owl:Restriction ; owl:onProperty cls:tieneRangoDelPar ; owl:hasValue poker:Diez ]
    )] .

cls:ManosDoblePar_As_Nueve a owl:Class ; rdfs:subClassOf cls:ManosDoblePar ;
    rdfs:label "Doble Par: Ases y Nueves" ;
    owl:equivalentClass [ a owl:Class ; owl:intersectionOf (
        cls:ManosDoblePar
        [ a owl:Restriction ; owl:onProperty cls:tieneRangoDelPar ; owl:hasValue poker:As ]
        [ a owl:Restriction ; owl:onProperty cls:tieneRangoDelPar ; owl:hasValue poker:Nueve ]
    )] .

cls:ManosDoblePar_As_Ocho a owl:Class ; rdfs:subClassOf cls:ManosDoblePar ;
    rdfs:label "Doble Par: Ases y Ochos" ;
