        [ a owl:Restriction ; owl:onProperty cls:tieneRangoDelPar ; owl:hasValue poker:As ]
        [ a owl:Restriction ; owl:onProperty cls:tieneRangoDelPar ; owl:hasValue poker:Dos ]
    )] .

# --- Pares con Rey (sin As) ---
cls:ManosDoblePar_Rey_Reina a owl:Class ; rdfs:subClassOf cls:ManosDoblePar ;
    rdfs:label "Doble Par: Reyes y Reinas" ;
    owl:equivalentClass [ a owl:Class ; owl:intersectionOf (
