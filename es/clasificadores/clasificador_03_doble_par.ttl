cls:ManosDoblePar_As_Dos a owl:Class ; rdfs:subClassOf cls:ManosDoblePar ;
    rdfs:label "Doble Par: Ases y Doses" ;
    owl:equivalentClass [ a owl:Class ; owl:intersectionOf (
